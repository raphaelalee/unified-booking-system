<%- include('partials/header', { title }) %>

<%
    const allBookingServices = typeof scopedServices !== 'undefined' && Array.isArray(scopedServices) && scopedServices.length > 0
        ? scopedServices
        : Array.isArray(merchant.services) && merchant.services.length > 0
            ? merchant.services
        : [{ id: 9001, name: 'QR Test Booking Service', duration: '30 mins', price: 20, slots: ['9:00 AM', '12:30 PM', '6:30 PM'] }];
    const requestedServiceId = String((form && form.serviceId) || (typeof selectedServiceId !== 'undefined' && selectedServiceId ? selectedServiceId : ''));
    const requestedOptionId = String((form && form.serviceOptionId) || '');
    const selectedBookingService = requestedServiceId
        ? allBookingServices.find((service) => String(service.id) === requestedServiceId)
        : null;
    const selectedBookingOption = selectedBookingService && requestedOptionId && Array.isArray(selectedBookingService.options)
        ? selectedBookingService.options.find((option) => String(option.id) === requestedOptionId)
        : null;
    const bookingServices = selectedBookingService ? [selectedBookingService] : allBookingServices;
    const promoDisplayPrice = selectedPromotion && typeof selectedPromotion.price === 'number'
        ? selectedPromotion.price
        : null;
    const promoOriginalPrice = selectedPromotion && typeof selectedPromotion.originalPrice === 'number'
        ? selectedPromotion.originalPrice
        : null;
    const lockPromotionOption = Boolean(selectedPromotion && requestedOptionId);
%>

<section class="booking-hero">
    <p class="eyebrow">Appointment booking</p>
    <h1>Book <%= merchant.name %></h1>
    <p><%= merchant.description %></p>
    <div class="booking-meta">
        <span><%= merchant.location %></span>
        <span>Rating <%= merchant.rating %></span>
        <span><%= bookingServices.length %> service<%= bookingServices.length === 1 ? '' : 's' %></span>
    </div>
    <% if (selectedPromotion) { %>
        <div class="notice">
            <p>
                Booking with promotion:
                <strong><%= selectedPromotion.campaignLabel || 'Promotion' %></strong>
                <% if (selectedPromotion.title) { %>
                    for <strong><%= selectedPromotion.title %></strong>
                <% } %>
            </p>
            <p>
                <% if (selectedPromotion.originalPrice) { %>
                    Original price: $<%= selectedPromotion.originalPrice %>.
                <% } %>
                <% if (selectedPromotion.price) { %>
                    Promo price: $<%= selectedPromotion.price %>.
                <% } %>
                <% if (selectedPromotion.discountPercent) { %>
                    Savings: <%= selectedPromotion.discountPercent %>% off.
                <% } %>
            </p>
        </div>
    <% } %>
</section>

<section class="section booking-layout">
    <div class="booking-services-panel">
        <div class="section-heading">
            <p class="eyebrow">Services</p>
            <h2>Choose an appointment</h2>
        </div>

        <div class="service-list">
            <% bookingServices.forEach((service) => { %>
                <% const activeOption = selectedBookingOption && String(selectedBookingService?.id) === String(service.id) ? selectedBookingOption : null; %>
                <% const bookableItem = activeOption || service; %>
                <% const displayPrice = promoDisplayPrice !== null ? promoDisplayPrice : bookableItem.price; %>
                <article class="booking-service-card">
                    <div>
                        <h3><%= service.name %><%= activeOption ? ' - ' + activeOption.name : '' %></h3>
                        <p class="muted">
                            <%= bookableItem.duration || service.duration %> &middot;
                            <% if (promoOriginalPrice !== null && promoDisplayPrice !== null) { %>
                                <span class="promotion-original-price">$<%= promoOriginalPrice %></span>
                            <% } %>
                            $<%= displayPrice %>
                        </p>
                        <% if (Array.isArray(service.options) && service.options.length > 0) { %>
                            <% if (activeOption) { %>
                                <p class="muted">
                                    Selected option: <%= activeOption.name %>
                                    <% if (promoDisplayPrice !== null) { %>
                                        ($<%= promoDisplayPrice %>)
                                    <% } else { %>
                                        ($<%= activeOption.price %>)
                                    <% } %>
                                </p>
                            <% } else { %>
                                <p class="muted">
                                    Options:
                                    <%= service.options.map((option) => option.name + ' ($' + option.price + ')').join(', ') %>
                                </p>
                            <% } %>
                        <% } %>
                        <p>Available: <%= (bookableItem.slots || service.slots).join(', ') %></p>
                    </div>
                    <span class="service-price">$<%= displayPrice %></span>
                </article>
            <% }) %>
        </div>
    </div>

    <aside class="booking-form-panel">
        <div>
            <p class="eyebrow">Your details</p>
            <h2>Confirm booking</h2>
            <p class="muted">Select a service, date, and time. We will save your booking request.</p>
        </div>

        <% if (errors.length > 0) { %>
            <div class="notice error">
                <% errors.forEach((error) => { %>
                    <p><%= error %></p>
                <% }) %>
            </div>
        <% } %>

        <form action="<%= typeof bookingPath !== 'undefined' ? bookingPath : '/booking/' + merchant.id + '/' + merchant.qrToken %>" method="POST" class="booking-form">
            <div class="form-row">
                <label>
                    Full name
                    <input type="text" name="customerName" value="<%= form.customerName || '' %>" placeholder="Enter your name">
                </label>
                <label>
                    Phone number
                    <input type="tel" name="phone" value="<%= form.phone || '' %>" placeholder="81234567" maxlength="8">
                </label>
            </div>

            <label>
                Email address
                <input type="email" name="email" value="<%= form.email || '' %>" placeholder="name@example.com">
            </label>

            <label>
                Service
                <select name="serviceId" class="js-service-select">
                    <option value="">Select a service</option>
                    <% bookingServices.forEach((service) => { %>
                        <option value="<%= service.id %>" <%= requestedServiceId === String(service.id) ? 'selected' : '' %>>
                            <%= service.name %> - $<%= service.price %>
                        </option>
                    <% }) %>
                </select>
            </label>

            <label>
                Option
                <% if (lockPromotionOption) { %>
                    <input type="hidden" name="serviceOptionId" value="<%= requestedOptionId %>">
                <% } %>
                <select name="<%= lockPromotionOption ? '' : 'serviceOptionId' %>" class="js-service-option-select" <%= lockPromotionOption ? 'disabled' : '' %>>
                    <option value="">Select an option</option>
                    <% bookingServices.forEach((service) => { %>
                        <% if (Array.isArray(service.options) && service.options.length > 0) { %>
                            <optgroup label="<%= service.name %>" data-service-id="<%= service.id %>">
                                <% service.options.forEach((option) => { %>
                                    <% const isSelectedPromoOption = promoDisplayPrice !== null && requestedOptionId === String(option.id); %>
                                    <option
                                        value="<%= option.id %>"
                                        data-service-id="<%= service.id %>"
                                        <%= requestedOptionId === String(option.id) ? 'selected' : '' %>>
                                        <%= option.name %> - <%= option.duration %> - $<%= isSelectedPromoOption ? promoDisplayPrice : option.price %>
                                    </option>
                                <% }) %>
                            </optgroup>
                        <% } %>
                    <% }) %>
                </select>
            </label>

            <div class="form-row">
                <label>
                    Date
                    <input type="date" name="bookingDate" value="<%= form.bookingDate || '' %>" min="<%= todayDate %>">
                </label>

                <label>
                    Time slot
                    <select name="bookingTime" class="js-time-select">
                        <option value="">Select a time</option>
                        <% bookingServices.forEach((service) => { %>
                            <% const options = Array.isArray(service.options) && service.options.length > 0 ? service.options : [service]; %>
                            <% options.forEach((option) => { %>
                                <optgroup label="<%= service.name %><%= option.id !== service.id ? ' - ' + option.name : '' %>" data-service-id="<%= service.id %>" data-service-option-id="<%= option.id %>">
                                    <% option.slots.forEach((slot) => { %>
                                        <option
                                            value="<%= slot %>"
                                            data-service-id="<%= service.id %>"
                                            data-service-option-id="<%= option.id %>"
                                            <%= form.bookingTime === slot ? 'selected' : '' %>>
                                            <%= slot %>
                                        </option>
                                    <% }) %>
                                </optgroup>
                            <% }) %>
                        <% }) %>
                    </select>
                </label>
            </div>

            <button class="button primary full" type="submit">Confirm booking</button>
        </form>
    </aside>
</section>

<script>
    (() => {
        const bookingForm = document.querySelector('.booking-form');
        const dateField = bookingForm?.querySelector('input[name="bookingDate"]');
        const selectedPromotion = <%- JSON.stringify(selectedPromotion || null) %>;

        if (!bookingForm || !dateField || !selectedPromotion || selectedPromotion.campaignLabel !== 'Happy Hour') {
            return;
        }

        const validateWeekendRule = () => {
            if (!dateField.value) {
                dateField.setCustomValidity('');
                return;
            }

            const selectedDate = new Date(`${dateField.value}T00:00:00`);

            if (Number.isNaN(selectedDate.getTime())) {
                dateField.setCustomValidity('');
                return;
            }

            const day = selectedDate.getDay();
            const isWeekday = day >= 1 && day <= 5;

            dateField.setCustomValidity(isWeekday ? '' : 'Happy Hour promotions can only be booked on weekdays.');
        };

        dateField.addEventListener('input', validateWeekendRule);
        dateField.addEventListener('change', validateWeekendRule);
        validateWeekendRule();
    })();
</script>

<%- include('partials/footer') %>
