<%- include('partials/header', { title }) %>

<%
    const formatBookingDate = (value) => {
        const date = value instanceof Date ? value : new Date(value);

        if (Number.isNaN(date.getTime())) {
            return value || '';
        }

        return date.toLocaleDateString('en-SG', {
            weekday: 'short',
            year: 'numeric',
            month: 'short',
            day: 'numeric'
        });
    };

    const formatPrice = (value) => Number(value || 0).toFixed(2);
%>

<section class="page-title">
    <p class="eyebrow">My Services</p>
    <h1>Your upcoming bookings.</h1>
    <p>Only bookings made from your account are shown here.</p>
</section>

<section class="section compact">
    <% if (bookings.length === 0) { %>
        <div class="notice">
            <p>You do not have any upcoming bookings yet.</p>
            <a class="button primary" href="/services">Browse services</a>
        </div>
    <% } else { %>
        <div class="service-catalog-grid unified-service-grid">
            <% bookings.forEach((booking) => { %>
                <article class="service-catalog-card unified-service-card">
                    <div class="portal-card-header">
                        <span class="tag"><%= booking.status %></span>
                        <span class="service-price slim">$<%= formatPrice(booking.service_price) %></span>
                    </div>
                    <div>
                        <h3><%= booking.service_name %></h3>
                        <p class="muted"><%= booking.merchant_name %></p>
                        <% if (booking.merchant_address) { %>
                            <p><%= booking.merchant_address %></p>
                        <% } %>
                    </div>
                    <div class="availability-strip">
                        <span><%= formatBookingDate(booking.booking_date) %></span>
                        <span><%= booking.booking_time %></span>
                    </div>
                </article>
            <% }) %>
        </div>
    <% } %>
</section>

<%- include('partials/footer') %>
