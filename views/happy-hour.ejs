<%- include('partials/header', { title }) %>

<%
    const offers = Array.isArray(promotionOffers) ? promotionOffers : [];
    const priceOptions = ['$', '$$', '$$$', '$$$$'].map((tier) => ({
        label: tier,
        value: tier,
        count: offers.filter((offer) => offer.priceTier === tier).length
    })).filter((option) => option.count > 0);
    const regionOptions = [...new Set(offers.map((offer) => offer.merchantLocation))].map((region) => ({
        label: region,
        value: region,
        count: offers.filter((offer) => offer.merchantLocation === region).length
    }));
    const categoryOptions = [...new Set(offers.map((offer) => offer.serviceCategory))].map((category) => ({
        label: category,
        value: category,
        count: offers.filter((offer) => offer.serviceCategory === category).length
    }));
%>

<section class="page-title promotions-page-title happy-hour-page-title">
    <div class="promotions-breadcrumbs">
        <a href="/">Home</a>
        <span>/</span>
        <a href="/promotions">Promotions</a>
        <span>/</span>
        <span>Happy Hour</span>
    </div>
    <h1>Happy Hour deals for off-peak salon and wellness slots.</h1>
    <p>Book during quieter weekday windows to unlock repeatable discounts on facials, hair services, massages and more without paying prime-time rates.</p>

    <div class="happy-hour-summary">
        <article>
            <h2>Time-restricted savings</h2>
            <p>These offers are usually tied to quieter hours like weekday mornings and afternoons, often between 10:00 AM and 4:00 PM.</p>
        </article>
        <article>
            <h2>Book more than once</h2>
            <p>Unlike first-trial deals, Happy Hour offers are often reusable as long as you can make the merchant's off-peak time window.</p>
        </article>
        <article>
            <h2>Flexible schedule wins</h2>
            <p>If you can step out on a lunch break or book midweek, this is one of the easiest ways to visit better salons more often.</p>
        </article>
    </div>
</section>

<section class="section compact promotions-layout">
    <aside class="promotions-filters" aria-label="Happy hour filters">
        <div class="filter-card">
            <div class="filter-card-header">
                <h2>Filters</h2>
                <button class="filter-clear-button" type="button">Clear All</button>
            </div>

            <div class="filter-group">
                <h3>Price</h3>
                <div class="filter-pill-row">
                    <% priceOptions.forEach((option) => { %>
                        <label class="filter-check">
                            <input type="checkbox" data-filter-group="price" value="<%= option.value %>">
                            <span><%= option.label %></span>
                        </label>
                    <% }) %>
                </div>
            </div>

            <div class="filter-group">
                <h3>Region</h3>
                <% regionOptions.forEach((option) => { %>
                    <label class="filter-line">
                        <input type="checkbox" data-filter-group="region" value="<%= option.value %>">
                        <span><%= option.label %></span>
                        <strong><%= option.count %></strong>
                    </label>
                <% }) %>
            </div>

            <div class="filter-group">
                <h3>Categories</h3>
                <% categoryOptions.forEach((option) => { %>
                    <label class="filter-line">
                        <input type="checkbox" data-filter-group="category" value="<%= option.value %>">
                        <span><%= option.label %></span>
                        <strong><%= option.count %></strong>
                    </label>
                <% }) %>
            </div>

            <div class="filter-group">
                <h3>Happy Hour notes</h3>
                <div class="happy-hour-copy-list">
                    <p>These slots are designed to fill quiet periods, so weekday daytime appointments are the most common.</p>
                    <p>Discounts are usually around 10% to 30% off standard pricing, which makes them ideal for regular upkeep.</p>
                    <p>Watch for overlap with 1-for-1 offers, because some off-peak windows can be stacked with bring-a-friend value.</p>
                </div>
            </div>
        </div>
    </aside>

    <div class="promotions-results">
        <div class="promotions-results-count">
            <strong data-promotions-count><%= offers.length %></strong> happy-hour services found.
        </div>

        <div class="promotions-list" data-promotions-list>
            <% offers.forEach((offer) => { %>
                <article
                    class="promotion-offer-card"
                    data-price="<%= offer.priceTier %>"
                    data-region="<%= offer.merchantLocation %>"
                    data-category="<%= offer.serviceCategory %>"
                >
                    <div class="promotion-offer-image promotion-offer-image-<%= offer.merchantId %>">
                        <span class="promotion-badge">Happy hour</span>
                        <span class="promotion-badge secondary">-<%= offer.discountPercent %>%</span>
                    </div>

                    <div class="promotion-offer-content">
                        <div class="promotion-offer-topline">
                            <div>
                                <h2>[HAPPY HOUR] <%= offer.name %></h2>
                                <p class="promotion-duration"><span class="duration-dot"></span><%= offer.duration %></p>
                            </div>
                            <div class="promotion-price-block">
                                <span class="promotion-original-price">$<%= offer.originalPrice %></span>
                                <strong>$<%= offer.price %></strong>
                            </div>
                        </div>

                        <div class="promotion-offer-meta">
                            <div>
                                <h3><%= offer.merchantName %></h3>
                                <p><%= offer.merchantPromotion %></p>
                                <p class="muted">Singapore &middot; <%= offer.merchantLocation %> &middot; <%= offer.merchantCategory %></p>
                                <p class="promotion-rating">&#9733;&#9733;&#9733;&#9733;&#9733; <span>(<%= offer.merchantRating %>)</span></p>
                            </div>
                            <a class="button primary" href="<%= offer.serviceBookingPath %>">Book now</a>
                        </div>

                        <div class="promotion-offer-tags">
                            <span>Happy Hour</span>
                            <span>Weekday off-peak</span>
                            <span>Repeatable deal</span>
                            <span><%= offer.serviceCategory %></span>
                        </div>
                    </div>
                </article>
            <% }) %>
        </div>

        <div class="notice promotions-empty-state is-hidden" data-promotions-empty>
            No happy-hour services match the selected filters.
        </div>
    </div>
</section>

<script src="/js/promotions-filters.js?v=1"></script>
<%- include('partials/footer') %>
