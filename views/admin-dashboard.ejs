<%- include('partials/header', { title }) %>

<section class="page-title">
    <p class="eyebrow">Admin Portal</p>
    <h1>Reporting and dashboards.</h1>
    <p>Admins can summarize customer information, merchant information, booking activity, validation issues, and error reporting across the whole platform.</p>
</section>

<section class="section compact">
    <% if (success) { %>
        <div class="notice success"><p><%= success %></p></div>
    <% } %>
    <% if (error) { %>
        <div class="notice error"><p><%= error %></p></div>
    <% } %>

    <% if (databaseError) { %>
        <div class="notice error">
            <p>Some dashboard database reporting could not be loaded. Check the validation report below for details.</p>
        </div>
    <% } %>

    <div class="portal-summary-panel admin-summary-panel dashboard-kpi-grid">
        <div class="portal-stat">
            <span>Customers</span>
            <strong><%= stats.customerCount %></strong>
            <small>registered customer accounts</small>
        </div>
        <div class="portal-stat">
            <span>Merchants</span>
            <strong><%= stats.merchantCount %></strong>
            <small><%= stats.merchantUserCount %> merchant users</small>
        </div>
        <div class="portal-stat">
            <span>Bookings</span>
            <strong><%= stats.bookingCount %></strong>
            <small><%= stats.uniqueBookedCustomers %> unique booked customers</small>
        </div>
        <div class="portal-stat">
            <span>Projected Revenue</span>
            <strong>$<%= stats.bookingRevenue.toFixed(2) %></strong>
            <small>from recorded bookings</small>
        </div>
    </div>

    <div class="dashboard-report-grid">
        <article class="dashboard-report-card">
            <p class="eyebrow">Customer Information</p>
            <h2>Customer summary</h2>
            <div class="report-metric-list">
                <p><span>Total customers</span><strong><%= customerReport.totalCustomers %></strong></p>
                <p><span>Booked customers</span><strong><%= customerReport.bookedCustomers %></strong></p>
                <p><span>Total VaniGlints</span><strong><%= customerReport.totalGlints %></strong></p>
            </div>
            <% if (customerReport.recentCustomers.length > 0) { %>
                <div class="dashboard-mini-list">
                    <% customerReport.recentCustomers.forEach((customer) => { %>
                        <div>
                            <strong><%= customer.name %></strong>
                            <span><%= customer.email %></span>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <p class="muted">No customer accounts found yet.</p>
            <% } %>
        </article>

        <article class="dashboard-report-card">
            <p class="eyebrow">Merchant Information</p>
            <h2>Merchant summary</h2>
            <div class="report-metric-list">
                <p><span>Total services</span><strong><%= merchantReport.totalServices %></strong></p>
                <p><span>Avg services / merchant</span><strong><%= stats.averageServicesPerMerchant.toFixed(1) %></strong></p>
                <p><span>No-service merchants</span><strong><%= merchantReport.merchantsWithoutServices.length %></strong></p>
            </div>
            <% if (merchantReport.topMerchant) { %>
                <div class="dashboard-highlight">
                    <span>Most complete merchant</span>
                    <strong><%= merchantReport.topMerchant.salon_name %></strong>
                    <small><%= merchantReport.topMerchant.service_count %> services</small>
                </div>
            <% } %>
        </article>

        <article class="dashboard-report-card validation-report-card <%= validationReport.issues.length > 0 ? 'needs-review' : 'healthy' %>">
            <p class="eyebrow">Validation & Error Reporting</p>
            <h2><%= validationReport.status %></h2>
            <% if (validationReport.issues.length === 0) { %>
                <p class="muted">No validation or dashboard loading issues detected.</p>
            <% } else { %>
                <ul class="validation-list">
                    <% validationReport.issues.forEach((issue) => { %>
                        <li><%= issue %></li>
                    <% }) %>
                </ul>
            <% } %>
        </article>
    </div>

    <div class="section-cta">
        <div>
            <p class="eyebrow">Site Management</p>
            <h2>Admin controls</h2>
            <p class="muted">Manage merchant accounts, services, and booking records from the admin area.</p>
        </div>
        <div class="admin-action-row">
            <a class="button primary" href="/admin/merchants/new">Add merchant</a>
            <a class="button secondary" href="/admin/services">Manage services</a>
            <a class="button secondary" href="/admin/promotions">Manage promotions</a>
        </div>
    </div>

    <div class="section-heading profile-heading">
        <p class="eyebrow">Merchants</p>
        <h2>Connected merchant accounts</h2>
    </div>

    <div class="merchant-list">
        <% merchants.forEach((merchant) => { %>
            <article class="merchant-row unified-merchant-row">
                <div class="merchant-thumb merchant-thumb-<%= merchant.salon_id %>">
                    <span>Merchant</span>
                </div>
                <div>
                    <div class="portal-card-header">
                        <p class="tag">Merchant</p>
                        <span class="sync-pill">Database</span>
                    </div>
                    <h2><%= merchant.salon_name %></h2>
                    <p class="muted"><%= merchant.address || 'No address set' %> &middot; Owner <%= merchant.owner_email %></p>
                    <p><%= merchant.description %></p>
                </div>
                <div class="merchant-actions">
                    <div class="portal-card-metrics compact">
                        <span><strong><%= merchant.service_count %></strong> services</span>
                        <span><strong>#<%= merchant.merchant_user_id %></strong> owner ID</span>
                    </div>
                </div>
            </article>
        <% }) %>
    </div>

    <div class="section-heading profile-heading">
        <p class="eyebrow">Bookings</p>
        <h2>Platform booking records</h2>
    </div>

    <% if (bookings.length === 0) { %>
        <div class="notice">
            <p>No bookings have been recorded yet.</p>
        </div>
    <% } else { %>
        <div class="admin-table-wrap">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Merchant</th>
                        <th>Service</th>
                        <th>Customer</th>
                        <th>Date</th>
                        <th>Time</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    <% bookings.forEach((booking) => { %>
                        <tr>
                            <td><%= booking.id %></td>
                            <td><%= booking.merchant_name || booking.merchantName %></td>
                            <td><%= booking.service_name || booking.serviceName %></td>
                            <td>
                                <strong><%= booking.customer_name || booking.customerName %></strong><br>
                                <span><%= booking.email %></span>
                            </td>
                            <td><%= booking.booking_date || booking.bookingDate %></td>
                            <td><%= booking.booking_time || booking.bookingTime %></td>
                            <td><span class="sync-pill"><%= booking.status %></span></td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    <% } %>
</section>

<%- include('partials/footer') %>
