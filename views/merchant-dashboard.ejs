<%- include('partials/header', { title }) %>

<section class="page-title merchant-dashboard-hero">
    <p class="eyebrow">Merchant Portal</p>
    <h1><%= merchant.name %></h1>
    <p>Overview, customer reporting, merchant health, and QR access for your own merchant account.</p>
</section>

<section class="section compact">
    <% if (success) { %>
        <div class="notice success"><p><%= success %></p></div>
    <% } %>
    <% if (error) { %>
        <div class="notice error"><p><%= error %></p></div>
    <% } %>

    <% if (databaseError) { %>
        <div class="notice error">
            <p>Booking records could not be loaded, so customer reporting is temporarily limited.</p>
        </div>
    <% } %>

    <div class="portal-summary-panel dashboard-kpi-grid merchant-kpi-grid">
        <div class="portal-stat">
            <span>Services</span>
            <strong><%= stats.serviceCount %></strong>
            <small><%= stats.slotCount %> available slots</small>
        </div>
        <div class="portal-stat">
            <span>Bookings</span>
            <strong><%= stats.bookingCount %></strong>
            <small><%= stats.customerCount %> unique customers</small>
        </div>
        <div class="portal-stat">
            <span>Projected Revenue</span>
            <strong>$<%= stats.bookingRevenue.toFixed(2) %></strong>
            <small>from your bookings</small>
        </div>
        <div class="portal-stat">
            <span>Avg Service Price</span>
            <strong>$<%= stats.averagePrice.toFixed(2) %></strong>
            <small>current menu average</small>
        </div>
        <div class="portal-stat">
            <span>Promotions</span>
            <strong><%= stats.promotionCount %></strong>
            <small>merchant campaigns</small>
        </div>
    </div>

    <div class="dashboard-report-grid">
        <article class="dashboard-report-card">
            <p class="eyebrow">Customer Information</p>
            <h2>Your customer activity</h2>
            <div class="report-metric-list">
                <p><span>Unique customers</span><strong><%= customerReport.totalCustomers %></strong></p>
                <p><span>Total bookings</span><strong><%= stats.bookingCount %></strong></p>
                <p><span>Booking revenue</span><strong>$<%= stats.bookingRevenue.toFixed(2) %></strong></p>
            </div>
            <% if (customerReport.recentBookings.length > 0) { %>
                <div class="dashboard-mini-list">
                    <% customerReport.recentBookings.forEach((booking) => { %>
                        <div>
                            <strong><%= booking.customer_name || booking.customerName %></strong>
                            <span><%= booking.service_name || booking.serviceName %> &middot; <%= booking.booking_date || booking.bookingDate %></span>
                        </div>
                    <% }) %>
                </div>
            <% } else { %>
                <p class="muted">No customer bookings have been recorded yet.</p>
            <% } %>
        </article>

        <article class="dashboard-report-card">
            <p class="eyebrow">Merchant Information</p>
            <h2>Your service summary</h2>
            <div class="report-metric-list">
                <p><span>Service categories</span><strong><%= merchantReport.categoryCount %></strong></p>
                <p><span>Available slots</span><strong><%= merchantReport.slotCount %></strong></p>
                <p><span>Active services</span><strong><%= merchantReport.serviceCount %></strong></p>
            </div>
            <% if (merchantReport.topService) { %>
                <div class="dashboard-highlight">
                    <span>Highest priced service</span>
                    <strong><%= merchantReport.topService.name %></strong>
                    <small>$<%= Number(merchantReport.topService.price).toFixed(2) %></small>
                </div>
            <% } else { %>
                <p class="muted">Add services to build your merchant report.</p>
            <% } %>
        </article>

        <article class="dashboard-report-card validation-report-card <%= validationReport.issues.length > 0 ? 'needs-review' : 'healthy' %>">
            <p class="eyebrow">Validation & Error Reporting</p>
            <h2><%= validationReport.status %></h2>
            <% if (validationReport.issues.length === 0) { %>
                <p class="muted">Your merchant profile and service setup look complete.</p>
            <% } else { %>
                <ul class="validation-list">
                    <% validationReport.issues.forEach((issue) => { %>
                        <li><%= issue %></li>
                    <% }) %>
                </ul>
            <% } %>
        </article>
    </div>

    <div class="section-heading merchant-workspace-heading">
        <p class="eyebrow">Merchant workspace</p>
        <h2>Dedicated controls</h2>
        <p class="muted">Each page now has one clear job, so dashboard reporting stays separate from editing tools.</p>
    </div>

    <div class="merchant-workspace-grid">
        <article class="merchant-workspace-card">
            <p class="eyebrow">Services</p>
            <h2>Menu, prices, and slots</h2>
            <p class="muted">Use this page only for service listings and availability.</p>
            <a class="button primary full" href="/merchant/services">Manage services</a>
        </article>
        <article class="merchant-workspace-card">
            <p class="eyebrow">Products</p>
            <h2>Retail catalogue</h2>
            <p class="muted">Add or update products shown on the customer product page.</p>
            <a class="button secondary full" href="/merchant/products">Manage products</a>
        </article>
        <article class="merchant-workspace-card">
            <p class="eyebrow">Promotions</p>
            <h2>Campaign offers</h2>
            <p class="muted">Control discounts, first trials, happy hour, and featured campaigns.</p>
            <a class="button secondary full" href="/merchant/promotions">Manage promotions</a>
        </article>
        <article class="merchant-workspace-card">
            <p class="eyebrow">Rewards Game</p>
            <h2>Game prizes</h2>
            <p class="muted">Create reward prizes customers can win through the game.</p>
            <a class="button secondary full" href="/merchant/rewards-game">Manage rewards</a>
        </article>
    </div>

    <div class="promo-panel qr-panel merchant-dashboard-qr">
        <p class="eyebrow">Merchant QR</p>
        <h2>Shop booking QR</h2>
        <p class="muted">
            This signed QR link is tied to merchant ID <%= merchant.id %> and opens only this merchant's booking flow.
        </p>
        <form action="/merchant/generate-qr" method="POST">
            <button class="button primary" type="submit">Generate QR Code</button>
        </form>
        <% if (qrCodeDataUrl && qrBookingUrl) { %>
            <a class="qr-code-link" href="<%= qrBookingUrl %>" aria-label="Open signed QR booking page">
                <img class="qr-code" src="<%= qrCodeDataUrl %>" alt="QR code for <%= merchant.name %> booking page">
            </a>
            <p class="muted">Encoded booking link:</p>
            <a class="text-link qr-link" href="<%= qrBookingUrl %>"><%= qrBookingUrl %></a>
        <% } %>
    </div>
</section>

<%- include('partials/footer') %>
