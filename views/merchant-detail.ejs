<%- include('partials/header', { title }) %>

<%
    const detailServices = Array.isArray(merchant.services) && merchant.services.length > 0
        ? merchant.services
        : [{ id: 9001, name: 'QR Test Booking Service', duration: '30 mins', price: 20, slots: ['9:00 AM', '12:30 PM', '6:30 PM'] }];
%>

<section class="page-title split">
    <div>
        <p class="eyebrow"><%= merchant.category %></p>
        <h1><%= merchant.name %></h1>
        <p><%= merchant.description %></p>
        <p class="muted"><%= merchant.location %> &middot; Rating <%= merchant.rating %></p>
        <form action="/merchants/<%= merchant.id %>/favourite" method="POST">
            <button class="heart-button large <%= isFavourite ? 'active' : '' %>" type="submit">
                <%- isFavourite ? '&hearts; Saved merchant' : '&#9825; Save merchant' %>
            </button>
        </form>
    </div>
    <div class="merchant-side-panels">
        <div class="promo-panel">
            <p class="eyebrow">Current promotion</p>
            <strong><%= merchant.promotion %></strong>
        </div>

        <div class="promo-panel qr-panel">
            <p class="eyebrow">QR booking</p>
            <h2>Scan to book</h2>
            <a class="qr-code-link" href="<%= bookingUrl %>" aria-label="Open booking page for <%= merchant.name %>">
                <img
                    class="qr-code"
                    src="https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=<%= encodedBookingUrl %>"
                    alt="QR code for <%= merchant.name %> booking page"
                >
            </a>
            <p class="muted">
                Customers can scan this code to open the booking page instantly without installing an app.
            </p>
            <a class="text-link qr-link" href="<%= bookingUrl %>"><%= bookingUrl %></a>
            <a class="button secondary full" href="/merchants/<%= merchant.id %>/qr">Open merchant QR page</a>
        </div>
    </div>
</section>

<section class="section two-column">
    <div>
        <div class="section-heading">
            <p class="eyebrow">Services</p>
            <h2>Availability and pricing</h2>
        </div>

        <div class="service-list">
            <% detailServices.forEach((service) => { %>
                <article class="service-card">
                    <div>
                        <h3><%= service.name %></h3>
                        <p class="muted"><%= service.duration %> &middot; $<%= service.price %></p>
                        <% if (Array.isArray(service.options) && service.options.length > 0) { %>
                            <p class="muted">
                                Options:
                                <%= service.options.map((option) => option.name + ' ($' + option.price + ')').join(', ') %>
                            </p>
                        <% } %>
                        <p>Available: <%= service.slots.join(', ') %></p>
                    </div>
                    <form action="/cart/add/<%= merchant.id %>" method="POST">
                        <input type="hidden" name="serviceId" value="<%= service.id %>">
                        <button class="button secondary" type="submit">Add to cart</button>
                    </form>
                </article>
            <% }) %>
        </div>
    </div>

    <aside class="booking-panel">
        <h2>Book appointment</h2>

        <% if (errors.length > 0) { %>
            <div class="notice error">
                <% errors.forEach((error) => { %>
                    <p><%= error %></p>
                <% }) %>
            </div>
        <% } %>

        <form action="/merchants/<%= merchant.id %>/book" method="POST" class="booking-form">
            <label>
                Full name
                <input type="text" name="customerName" value="<%= form.customerName || '' %>" placeholder="Enter your name">
            </label>

            <label>
                Email
                <input type="email" name="email" value="<%= form.email || '' %>" placeholder="name@example.com">
            </label>

            <label>
                Phone number
                <input type="tel" name="phone" value="<%= form.phone || '' %>" placeholder="81234567" maxlength="8">
            </label>

            <label>
                Service
                <select name="serviceId" class="js-service-select">
                    <option value="">Select a service</option>
                    <% detailServices.forEach((service) => { %>
                        <option value="<%= service.id %>" <%= String(form.serviceId) === String(service.id) ? 'selected' : '' %>>
                            <%= service.name %> - $<%= service.price %>
                        </option>
                    <% }) %>
                </select>
            </label>

            <label>
                Option
                <select name="serviceOptionId" class="js-service-option-select">
                    <option value="">Select an option</option>
                    <% detailServices.forEach((service) => { %>
                        <% if (Array.isArray(service.options) && service.options.length > 0) { %>
                            <optgroup label="<%= service.name %>" data-service-id="<%= service.id %>">
                                <% service.options.forEach((option) => { %>
                                    <option
                                        value="<%= option.id %>"
                                        data-service-id="<%= service.id %>"
                                        <%= String(form.serviceOptionId) === String(option.id) ? 'selected' : '' %>>
                                        <%= option.name %> - <%= option.duration %> - $<%= option.price %>
                                    </option>
                                <% }) %>
                            </optgroup>
                        <% } %>
                    <% }) %>
                </select>
            </label>

            <label>
                Date
                <input type="date" name="bookingDate" value="<%= form.bookingDate || '' %>" min="<%= todayDate %>">
            </label>

            <label>
                Time slot
                <select name="bookingTime" class="js-time-select">
                    <option value="">Select a time</option>
                    <% detailServices.forEach((service) => { %>
                        <% const options = Array.isArray(service.options) && service.options.length > 0 ? service.options : [service]; %>
                        <% options.forEach((option) => { %>
                            <optgroup label="<%= service.name %><%= option.id !== service.id ? ' - ' + option.name : '' %>" data-service-id="<%= service.id %>" data-service-option-id="<%= option.id %>">
                                <% option.slots.forEach((slot) => { %>
                                    <option
                                        value="<%= slot %>"
                                        data-service-id="<%= service.id %>"
                                        data-service-option-id="<%= option.id %>"
                                        <%= form.bookingTime === slot ? 'selected' : '' %>>
                                        <%= slot %>
                                    </option>
                                <% }) %>
                            </optgroup>
                        <% }) %>
                    <% }) %>
                </select>
            </label>

            <button class="button primary full" type="submit">Submit booking request</button>
        </form>
    </aside>
</section>

<%- include('partials/footer') %>
