<%- include('partials/header', { title }) %>

<%
    const detailServices = Array.isArray(merchant.services) ? merchant.services : [];
    const priceValues = detailServices.map((service) => Number(service.price)).filter((price) => Number.isFinite(price));
    const startingPrice = priceValues.length > 0 ? Math.min(...priceValues) : 0;
    const slotCount = detailServices.reduce((total, service) => total + (Array.isArray(service.slots) ? service.slots.length : 0), 0);
    const categories = [...new Set(detailServices.map((service) => service.name).filter(Boolean))];
%>

<section class="merchant-info-page">
    <div class="merchant-info-back-row">
        <a class="text-link" href="<%= typeof backUrl !== 'undefined' ? backUrl : '/services' %>">
            &larr; <%= typeof backLabel !== 'undefined' ? backLabel : 'Back to services' %>
        </a>
    </div>

    <section class="merchant-info-hero">
        <div class="merchant-info-copy">
            <p class="eyebrow"><%= merchant.category %></p>
            <h1><%= merchant.name %></h1>
            <p><%= merchant.description %></p>
            <div class="merchant-info-meta">
                <span><%= merchant.location %></span>
                <span>Rating <%= merchant.rating %></span>
                <span><%= detailServices.length %> services</span>
            </div>
        </div>
        <aside class="merchant-info-image merchant-thumb-<%= merchant.id %>" aria-label="<%= merchant.name %>"></aside>
    </section>

    <section class="merchant-info-grid">
        <article class="merchant-info-panel">
            <p class="eyebrow">Merchant information</p>
            <h2>About this partner</h2>
            <p><%= merchant.description %></p>
            <div class="merchant-fact-grid">
                <div>
                    <span>Location</span>
                    <strong><%= merchant.location %></strong>
                </div>
                <div>
                    <span>Category</span>
                    <strong><%= merchant.category %></strong>
                </div>
                <div>
                    <span>Rating</span>
                    <strong><%= merchant.rating %></strong>
                </div>
                <div>
                    <span>From</span>
                    <strong><%= startingPrice > 0 ? '$' + startingPrice : 'View menu' %></strong>
                </div>
            </div>
        </article>

        <article class="merchant-info-panel merchant-info-highlight">
            <p class="eyebrow">Current highlight</p>
            <h2><%= merchant.promotion %></h2>
            <p class="muted">
                This page is for merchant information only. Use the services page when you want to choose a service and continue the booking flow.
            </p>
            <a class="button secondary full" href="<%= typeof backUrl !== 'undefined' ? backUrl : '/services' %>">
                <%= typeof backLabel !== 'undefined' ? backLabel : 'Back to services' %>
            </a>
        </article>
    </section>

    <section class="section compact merchant-info-services">
        <div class="section-heading">
            <p class="eyebrow">Service menu preview</p>
            <h2>What this merchant offers</h2>
            <p class="muted">
                Read-only overview with service names, prices, durations, and available times.
            </p>
        </div>

        <% if (detailServices.length === 0) { %>
            <div class="notice">
                <p>This merchant has not listed services yet.</p>
            </div>
        <% } else { %>
            <div class="merchant-info-service-grid">
                <% detailServices.forEach((service) => { %>
                    <article class="merchant-info-service-card">
                        <div class="portal-card-header">
                            <span class="tag"><%= service.name %></span>
                            <span class="service-price slim">$<%= service.price %></span>
                        </div>
                        <h3><%= service.name %></h3>
                        <p class="muted"><%= service.duration %></p>
                        <% if (Array.isArray(service.options) && service.options.length > 0) { %>
                            <p>
                                <%= service.options.map((option) => option.name).join(', ') %>
                            </p>
                        <% } %>
                        <% if (Array.isArray(service.slots) && service.slots.length > 0) { %>
                            <div class="availability-strip compact-slots">
                                <% service.slots.forEach((slot) => { %>
                                    <span><%= slot %></span>
                                <% }) %>
                            </div>
                        <% } %>
                    </article>
                <% }) %>
            </div>
        <% } %>
    </section>

    <section class="merchant-info-footer-panel">
        <div>
            <p class="eyebrow">At a glance</p>
            <h2><%= merchant.name %></h2>
        </div>
        <div class="merchant-info-summary">
            <span><strong><%= categories.length %></strong> categories</span>
            <span><strong><%= slotCount %></strong> available times</span>
            <span><strong><%= merchant.integrationStatus || 'Listed' %></strong> status</span>
        </div>
    </section>
</section>

<%- include('partials/footer') %>
