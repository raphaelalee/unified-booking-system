<%- include('partials/header', { title }) %>

<section class="hero">
    <div class="hero-content">
        <p class="eyebrow">Beauty bookings and rewards</p>
        <h1>Vaniday</h1>
        <p class="hero-text">
            A refined place to discover beauty, spa, grooming, products, rewards, and appointment times.
        </p>
        <div class="hero-actions">
            <a class="button primary" href="/services">Explore services</a>
            <a class="button secondary" href="/merchants">View merchants</a>
        </div>
    </div>
    <div class="hero-visual" aria-label="Luxury beauty product editorial"></div>
</section>

<% if (success) { %>
    <section class="notice success">
        <%= success %>
    </section>
<% } %>

<section class="section">
    <div class="editorial-section-heading">
        <div>
            <p class="eyebrow">Featured merchants</p>
            <h2>Selected Vaniday partners</h2>
        </div>
        <a class="text-link" href="/merchants">View directory</a>
    </div>

    <div class="merchant-grid home-editorial-grid">
        <% merchants.forEach((merchant, index) => { %>
            <article class="merchant-card">
                <div class="merchant-card-image merchant-thumb-<%= merchant.id %>" aria-hidden="true"></div>
                <div>
                    <p class="tag"><%= merchant.category %></p>
                    <h3><%= merchant.name %></h3>
                    <p class="muted"><%= merchant.location %> &middot; Rating <%= merchant.rating %></p>
                    <p><%= merchant.description %></p>
                </div>
                <div class="card-footer">
                    <span class="promotion"><%= merchant.promotion %></span>
                    <a class="text-link" href="/merchants/<%= merchant.id %>">View services</a>
                </div>
            </article>
        <% }) %>
    </div>
</section>

<%- include('partials/footer') %>
