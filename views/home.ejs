<%- include('partials/header', { title }) %>

<section class="hero">
    <div class="hero-content">
        <p class="eyebrow">Wellness and salon booking</p>
        <h1>Naturally effortless beauty appointments.</h1>
        <p class="hero-text">
            Discover trusted salons, spas, and grooming merchants. Scan a QR code,
            choose a service, and confirm your appointment from one elegant booking page.
        </p>
        <div class="hero-actions">
            <a class="button primary" href="/services">Browse services</a>
            <a class="button secondary" href="/about">About project</a>
        </div>
    </div>
    <div class="hero-visual" aria-label="Salon products and wellness ambience"></div>
</section>

<% if (success) { %>
    <section class="notice success">
        <%= success %>
    </section>
<% } %>

<section class="section">
    <div class="section-heading">
        <p class="eyebrow">Featured merchants</p>
        <h2>Popular Vaniday partners</h2>
    </div>

    <div class="merchant-grid">
        <% merchants.forEach((merchant) => { %>
            <article class="merchant-card">
                <div>
                    <p class="tag"><%= merchant.category %></p>
                    <h3><%= merchant.name %></h3>
                    <p class="muted"><%= merchant.location %> &middot; Rating <%= merchant.rating %></p>
                    <p><%= merchant.description %></p>
                </div>
                <div class="card-footer">
                    <span class="promotion"><%= merchant.promotion %></span>
                    <a class="text-link" href="/merchants/<%= merchant.id %>">View services</a>
                </div>
            </article>
        <% }) %>
    </div>
</section>

<%- include('partials/footer') %>
