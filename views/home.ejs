<%- include('partials/header', { title }) %>

<section class="hero">
    <div class="hero-content">
        <p class="eyebrow">Unified booking marketplace</p>
        <h1>Book beauty and wellness services across Vaniday merchants.</h1>
        <p class="hero-text">
            Vaniday helps customers discover merchants, compare services, view promotions,
            and send booking requests from one simple portal.
        </p>
        <div class="hero-actions">
            <a class="button primary" href="/merchants">Browse merchants</a>
            <a class="button secondary" href="/about">View project scope</a>
        </div>
    </div>
</section>

<% if (success) { %>
    <section class="notice success">
        <%= success %>
    </section>
<% } %>

<section class="section">
    <div class="section-heading">
        <p class="eyebrow">Featured merchants</p>
        <h2>Popular Vaniday partners</h2>
    </div>

    <div class="merchant-grid">
        <% merchants.forEach((merchant) => { %>
            <article class="merchant-card">
                <div>
                    <p class="tag"><%= merchant.category %></p>
                    <h3><%= merchant.name %></h3>
                    <p class="muted"><%= merchant.location %> · Rating <%= merchant.rating %></p>
                    <p><%= merchant.description %></p>
                </div>
                <div class="card-footer">
                    <span class="promotion"><%= merchant.promotion %></span>
                    <a class="text-link" href="/merchants/<%= merchant.id %>">View services</a>
                </div>
            </article>
        <% }) %>
    </div>
</section>

<%- include('partials/footer') %>
