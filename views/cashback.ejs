<%- include('partials/header', { title }) %>

<section class="page-title">
    <p class="eyebrow">Cashback</p>
    <h1>Earn rewards when you book with Vaniday.</h1>
    <p>Cashback encourages customers to return while helping merchants build loyalty.</p>
</section>

<section class="section compact">
    <div class="cashback-panel">
        <div>
            <p class="eyebrow">Current Reward</p>
            <h2>Up to 10% cashback</h2>
            <p>Book selected beauty, salon, and spa services to earn cashback credits for future appointments.</p>
            <a class="button primary" href="/services">Book an appointment</a>
        </div>
        <div class="cashback-badge">
            <span>10%</span>
            <small>cashback</small>
        </div>
    </div>

    <div class="feature-grid">
        <article>
            <h2>1. Book</h2>
            <p>Select a merchant and submit your booking request.</p>
        </article>
        <article>
            <h2>2. Visit</h2>
            <p>Attend your appointment and complete payment at the merchant.</p>
        </article>
        <article>
            <h2>3. Earn</h2>
            <p>Cashback is added to your Vaniday profile for the next booking.</p>
        </article>
    </div>
</section>

<%- include('partials/footer') %>
