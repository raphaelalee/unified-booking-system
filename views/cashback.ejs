<%- include('partials/header', { title }) %>

<section class="page-title">
    <p class="eyebrow">Cashback</p>
    <h1>Earn rewards when you book with Vaniday.</h1>
    <p>Your cashback is stored in your wallet and can be used on future payments.</p>
</section>

<section class="section compact">
    <div class="cashback-panel">
        <div>
            <p class="eyebrow">Current wallet</p>
            <h2>$<%= Number(wallet.cashbackBalance || 0).toFixed(2) %> cashback available</h2>
            <p>
                Earn <%= rules.pointsPerDollar %> points per dollar and
                <%= rules.cashbackPercent %>% cashback after completed payments.
            </p>
            <div class="hero-actions">
                <a class="button primary" href="/services">Book an appointment</a>
                <a class="button secondary" href="/profile#wallet">View wallet</a>
            </div>
        </div>
        <div class="cashback-badge">
            <span><%= rules.cashbackPercent %>%</span>
            <small>cashback</small>
        </div>
    </div>

    <div class="feature-grid">
        <article>
            <h2>1. Pay</h2>
            <p>Complete a booking or product checkout through Vaniday.</p>
        </article>
        <article>
            <h2>2. Earn</h2>
            <p>Points and cashback are added to your wallet from the trusted receipt amount.</p>
        </article>
        <article>
            <h2>3. Redeem</h2>
            <p>Use available cashback on future Vaniday payments.</p>
        </article>
    </div>
</section>

<%- include('partials/footer') %>
