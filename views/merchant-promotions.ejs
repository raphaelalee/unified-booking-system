<%- include('partials/header', { title }) %>

<%
    const formatPromotionDate = (value) => {
        const date = value instanceof Date ? value : new Date(value);

        if (Number.isNaN(date.getTime())) {
            return '';
        }

        return date.toLocaleString('en-SG', {
            year: 'numeric',
            month: 'short',
            day: 'numeric',
            hour: 'numeric',
            minute: '2-digit'
        });
    };
%>

<section class="page-title">
    <p class="eyebrow">Merchant Portal</p>
    <h1>Manage promotions</h1>
    <p><%= merchant.name %> can only manage promotions under this merchant profile.</p>
</section>

<section class="section compact">
    <% if (success) { %>
        <div class="notice success"><p><%= success %></p></div>
    <% } %>
    <% if (error) { %>
        <div class="notice error"><p><%= error %></p></div>
    <% } %>

    <div class="section-cta">
        <div>
            <h2>Promotion campaigns</h2>
            <p class="muted"><%= promotions.length %> promotions currently linked to this merchant.</p>
        </div>
        <a class="button primary" href="/merchant/promotions/new">Add promotion</a>
    </div>

    <% if (promotions.length === 0) { %>
        <div class="notice">
            No promotions have been created yet. Add one to start running first-trial, happy hour, 1-for-1, or featured campaigns.
        </div>
    <% } else { %>
        <div class="service-catalog-grid unified-service-grid">
            <% promotions.forEach((promotion) => { %>
                <article class="service-catalog-card unified-service-card">
                    <div class="portal-card-header">
                        <span class="tag"><%= promotion.type.replace(/_/g, ' ') %></span>
                        <span class="service-price slim"><%= promotion.status %></span>
                    </div>
                    <div>
                        <h3><%= promotion.title %></h3>
                        <p class="muted">
                            <%= promotion.serviceName || 'All merchant services' %> &middot;
                            <%= promotion.discountType.replace(/_/g, ' ') %>
                            <% if (promotion.discountValue !== null) { %>
                                &middot; <%= promotion.discountValue %>
                            <% } %>
                        </p>
                        <% if (promotion.description) { %>
                            <p><%= promotion.description %></p>
                        <% } %>
                        <% if (promotion.terms) { %>
                            <p class="muted"><%= promotion.terms %></p>
                        <% } %>
                    </div>
                    <div class="availability-strip">
                        <span>Starts <%= formatPromotionDate(promotion.startDate) %></span>
                        <span>Ends <%= formatPromotionDate(promotion.endDate) %></span>
                    </div>
                    <div class="service-card-actions">
                        <a class="button secondary full" href="/merchant/promotions/<%= promotion.id %>/edit">Edit</a>
                        <form action="/merchant/promotions/<%= promotion.id %>/delete" method="POST">
                            <button class="button secondary full danger-button" type="submit">Delete</button>
                        </form>
                    </div>
                </article>
            <% }) %>
        </div>
    <% } %>
</section>

<%- include('partials/footer') %>
