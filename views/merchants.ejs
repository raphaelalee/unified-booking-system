<%- include('partials/header', { title }) %>

<section class="page-title">
    <p class="eyebrow">Merchant Directory</p>
    <h1>Find your next beauty appointment.</h1>
    <p>Browse salons, spas, grooming studios, and wellness merchants with instant QR booking links.</p>
</section>

<section class="section compact">
    <form class="search-bar" action="/merchants" method="GET">
        <input type="search" name="search" value="<%= search %>" placeholder="Search merchants, category, or location">
        <button class="button primary" type="submit">Search</button>
    </form>

    <% if (merchants.length === 0) { %>
        <div class="notice">
            No merchants found. Try searching for beauty, spa, barber, or a location.
        </div>
    <% } %>

    <div class="merchant-list">
        <% merchants.forEach((merchant, index) => { %>
            <article class="merchant-row">
                <div class="merchant-thumb merchant-thumb-<%= merchant.id %>">
                    <span><%= merchant.category %></span>
                </div>
                <div>
                    <div class="merchant-title-row">
                        <p class="tag"><%= merchant.category %></p>
                        <form action="/merchants/<%= merchant.id %>/favourite" method="POST">
                            <button class="heart-button <%= favouriteIds.includes(merchant.id) ? 'active' : '' %>" type="submit" aria-label="Favourite <%= merchant.name %>">
                                <%- favouriteIds.includes(merchant.id) ? '&hearts;' : '&#9825;' %>
                            </button>
                        </form>
                    </div>
                    <h2><%= merchant.name %></h2>
                    <p class="muted"><%= merchant.location %> &middot; Rating <%= merchant.rating %></p>
                    <p><%= merchant.description %></p>
                    <p class="promotion"><%= merchant.promotion %></p>
                </div>
                <div class="merchant-actions">
                    <a class="button primary" href="/merchants/<%= merchant.id %>">View merchant</a>
                    <a class="text-link" href="/merchants/<%= merchant.id %>/qr">QR booking</a>
                </div>
            </article>
        <% }) %>
    </div>
</section>

<%- include('partials/footer') %>
