<%- include('partials/header', { title }) %>

<%
    const services = Array.isArray(merchant.services) ? merchant.services : [];
    const categoryOptions = [...new Set(services.map((service) => service.category || merchant.category).filter(Boolean))].sort((left, right) => left.localeCompare(right));
    const slotCount = services.reduce((total, service) => total + (Array.isArray(service.slots) ? service.slots.length : 0), 0);
    const averagePrice = services.length > 0
        ? services.reduce((total, service) => total + Number(service.price || 0), 0) / services.length
        : 0;
%>

<section class="page-title merchant-services-hero">
    <p class="eyebrow">Merchant Portal</p>
    <h1>My services</h1>
    <p>Manage only your service menu, prices, duration, and available slots for <%= merchant.name %>.</p>
</section>

<section class="section compact merchant-service-manager-page">
    <% if (success) { %>
        <div class="notice success"><p><%= success %></p></div>
    <% } %>
    <% if (error) { %>
        <div class="notice error"><p><%= error %></p></div>
    <% } %>

    <div class="portal-summary-panel merchant-service-summary">
        <div class="portal-stat">
            <span>Listed services</span>
            <strong><%= services.length %></strong>
            <small><%= categoryOptions.length %> categories</small>
        </div>
        <div class="portal-stat">
            <span>Available slots</span>
            <strong><%= slotCount %></strong>
            <small>across all services</small>
        </div>
        <div class="portal-stat">
            <span>Average price</span>
            <strong>$<%= averagePrice.toFixed(2) %></strong>
            <small>current service menu</small>
        </div>
    </div>

    <div class="section-cta merchant-service-toolbar">
        <div>
            <p class="eyebrow">Service manager</p>
            <h2>Menu and availability</h2>
            <p class="muted">Products, promotions, and game rewards live on their own dedicated pages.</p>
        </div>
        <div class="inline-button-group">
            <% if (categoryOptions.length > 1) { %>
                <label>
                    <span class="sr-only">Filter by category</span>
                    <select class="js-merchant-service-category-filter">
                        <option value="">All categories</option>
                        <% categoryOptions.forEach((category) => { %>
                            <option value="<%= category %>"><%= category %></option>
                        <% }) %>
                    </select>
                </label>
            <% } %>
            <a class="button secondary" href="/merchant">Back to dashboard</a>
            <a class="button primary" href="/merchant/services/new">Add service</a>
        </div>
    </div>

    <% if (services.length === 0) { %>
        <div class="notice">
            <p>No services are listed yet. Add your first service so customers can start booking.</p>
        </div>
    <% } else { %>
        <div class="service-catalog-grid unified-service-grid merchant-service-grid">
            <% services.forEach((service) => { %>
                <article class="service-catalog-card unified-service-card js-merchant-service-card" data-category="<%= service.category || merchant.category %>">
                    <div class="portal-card-header">
                        <span class="tag"><%= service.category || merchant.category %></span>
                        <span class="service-price slim">$<%= Number(service.price).toFixed(2) %></span>
                    </div>
                    <div>
                        <h3><%= service.name %></h3>
                        <p class="muted"><%= service.duration %></p>
                        <% if (service.description) { %>
                            <p><%= service.description %></p>
                        <% } %>
                    </div>
                    <% if (Array.isArray(service.slots) && service.slots.length > 0) { %>
                        <div class="availability-strip compact-slots">
                            <% service.slots.forEach((slot) => { %>
                                <span><%= slot %></span>
                            <% }) %>
                        </div>
                    <% } else { %>
                        <p class="muted">No slots configured yet.</p>
                    <% } %>
                    <div class="service-card-actions">
                        <a class="button secondary full" href="/merchant/services/<%= service.id %>/edit">Edit</a>
                        <form action="/merchant/services/<%= service.id %>/delete" method="POST">
                            <button class="button secondary full danger-button" type="submit">Delete</button>
                        </form>
                    </div>
                </article>
            <% }) %>
        </div>
    <% } %>
</section>

<script>
    (() => {
        const categoryFilter = document.querySelector('.js-merchant-service-category-filter');
        const serviceCards = Array.from(document.querySelectorAll('.js-merchant-service-card'));

        if (!categoryFilter || serviceCards.length === 0) {
            return;
        }

        categoryFilter.addEventListener('change', () => {
            const selectedCategory = categoryFilter.value.trim().toLowerCase();

            serviceCards.forEach((card) => {
                const category = (card.dataset.category || '').trim().toLowerCase();
                card.style.display = !selectedCategory || category === selectedCategory ? '' : 'none';
            });
        });
    })();
</script>

<%- include('partials/footer') %>
