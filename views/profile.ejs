<%- include('partials/header', { title }) %>

<%
    const profileUpcomingBookings = typeof upcomingBookings !== 'undefined' && Array.isArray(upcomingBookings)
        ? upcomingBookings
        : [];
    const profilePastBookings = typeof pastBookings !== 'undefined' && Array.isArray(pastBookings)
        ? pastBookings
        : [];
%>

<section class="section compact account-settings-page profile-redesign-page">
    <% if (success) { %>
        <div class="notice success"><%= success %></div>
    <% } %>
    <% if (error) { %>
        <div class="notice error"><%= error %></div>
    <% } %>

    <div class="profile-page-heading">
        <div>
            <p class="eyebrow"><%= roleLabel %> Profile</p>
            <h1>Account settings.</h1>
            <p>Keep your contact details and password up to date.</p>
        </div>
        <a class="button secondary" href="<%= isCustomer ? '/services' : dashboardPath %>">&larr; Back</a>
    </div>

    <section class="profile-hero-card">
        <div class="account-avatar profile-hero-avatar" aria-hidden="true">
            <%= (profile.name || roleLabel || 'V').charAt(0).toUpperCase() %>
        </div>

        <div class="profile-hero-details">
            <span class="account-role-chip"><%= roleLabel %></span>
            <h2><%= profile.name %></h2>
            <p><%= profile.email %></p>
            <p><%= profile.phone || 'Phone not set' %></p>
            <% if (isCustomer) { %>
                <p>VaniGlints: <strong><%= Number.isFinite(profile.glintsBalance) ? profile.glintsBalance : 0 %> pts</strong></p>
                <p>Membership: <strong><%= member.tier %></strong></p>
            <% } %>
        </div>

        <div class="profile-hero-actions">
            <% if (isCustomer) { %>
                <a class="button primary full" href="/services">Book services</a>
                <a class="button secondary full" href="#wallet">Rewards wallet</a>
            <% } else { %>
                <a class="button primary full" href="<%= dashboardPath %>">Back to dashboard</a>
            <% } %>
            <form action="/logout" method="POST">
                <button class="text-button full" type="submit">Log out</button>
            </form>
        </div>
    </section>

    <nav class="profile-tab-nav" aria-label="Profile sections">
        <a href="#profile-details" data-profile-tab="profile-details">Profile</a>
        <% if (isCustomer) { %>
            <a href="#bookings" data-profile-tab="bookings">Bookings</a>
            <a href="#wallet" data-profile-tab="wallet">Wallet</a>
            <a href="#membership" data-profile-tab="membership">Rewards</a>
        <% } %>
        <a href="#settings" data-profile-tab="settings">Settings</a>
    </nav>

    <div class="account-layout">
        <aside class="account-summary-panel profile-side-summary">
            <div class="account-avatar" aria-hidden="true">
                <%= (profile.name || roleLabel || 'V').charAt(0).toUpperCase() %>
            </div>

            <div class="account-name-block">
                <span class="account-role-chip"><%= roleLabel %></span>
                <h2><%= profile.name %></h2>
                <p><%= profile.email %></p>
            </div>

            <dl class="account-summary-list">
                <div>
                    <dt>Phone</dt>
                    <dd><%= profile.phone || 'Not set' %></dd>
                </div>
                <% if (isCustomer) { %>
                    <div>
                        <dt>Membership</dt>
                        <dd><%= member.tier %></dd>
                    </div>
                    <div>
                        <dt>VaniGlints</dt>
                        <dd><%= Number.isFinite(profile.glintsBalance) ? profile.glintsBalance : 0 %> pts</dd>
                    </div>
                    <div>
                        <dt>Cashback</dt>
                        <dd>$<%= cashbackBalance %></dd>
                    </div>
                    <% if (referral) { %>
                        <div>
                            <dt>Referral code</dt>
                            <dd><%= referral.code %></dd>
                        </div>
                    <% } %>
                <% } else { %>
                    <div>
                        <dt>Dashboard</dt>
                        <dd><a href="<%= dashboardPath %>">Open dashboard</a></dd>
                    </div>
                <% } %>
            </dl>

            <div class="account-actions">
                <% if (isCustomer) { %>
                    <a class="button primary full" href="/services">Book services</a>
                    <a class="button secondary full" href="/profile/history">Purchase history</a>
                    <a class="button secondary full" href="/rewards-game">Rewards game</a>
                    <a class="button secondary full" href="#wallet">Rewards wallet</a>
                <% } else { %>
                    <a class="button primary full" href="<%= dashboardPath %>">Back to dashboard</a>
                <% } %>
                <form action="/logout" method="POST">
                    <button class="text-button full" type="submit">Log out</button>
                </form>
            </div>
        </aside>

        <div class="account-main-stack">
            <form id="profile-details" class="account-panel account-form profile-tab-panel" data-profile-panel="profile-details" action="/profile" method="POST">
                <div class="account-panel-header">
                    <div>
                        <p class="eyebrow">Details</p>
                        <h2>Personal information</h2>
                    </div>
                </div>

                <div class="form-grid">
                    <label>
                        Full name
                        <input type="text" name="name" value="<%= profile.name %>" placeholder="Enter your name" autocomplete="name" required>
                    </label>

                    <label>
                        Email
                        <input type="email" name="email" value="<%= profile.email %>" placeholder="name@example.com" autocomplete="email" required>
                    </label>

                    <label>
                        Handphone number
                        <input type="tel" name="phone" value="<%= profile.phone %>" placeholder="81234567" maxlength="8" pattern="[689][0-9]{7}" autocomplete="tel">
                    </label>
                </div>

                <div class="account-form-actions">
                    <button class="button primary" type="submit">Save changes</button>
                </div>
            </form>

            <form id="settings" class="account-panel account-form profile-tab-panel" data-profile-panel="settings" action="/profile/password" method="POST">
                <div class="account-panel-header">
                    <div>
                        <p class="eyebrow">Security</p>
                        <h2>Change password</h2>
                    </div>
                </div>

                <div class="form-grid">
                    <label>
                        Current password
                        <input type="password" name="currentPassword" placeholder="Current password" autocomplete="current-password" required>
                    </label>

                    <label>
                        New password
                        <input type="password" name="newPassword" placeholder="New password" autocomplete="new-password" minlength="8" required>
                    </label>

                    <label>
                        Confirm new password
                        <input type="password" name="confirmPassword" placeholder="Confirm password" autocomplete="new-password" minlength="8" required>
                    </label>
                </div>

                <div class="password-requirements">
                    <span>Current password required</span>
                    <span>8+ characters</span>
                    <span>Letters and numbers</span>
                </div>

                <div class="account-form-actions">
                    <button class="button primary" type="submit">Update password</button>
                </div>
            </form>

            <% if (isCustomer) { %>
                <section id="bookings" class="account-panel profile-tab-panel" data-profile-panel="bookings">
                    <div class="account-panel-header">
                        <div>
                            <p class="eyebrow">Bookings</p>
                            <h2>Upcoming Bookings</h2>
                        </div>
                        <a class="button secondary" href="/services">Book services</a>
                    </div>

                    <% if (!profileUpcomingBookings.length) { %>
                        <p class="muted">No upcoming bookings yet.</p>
                    <% } else { %>
                        <div class="saved-merchant-list">
                            <% profileUpcomingBookings.forEach((booking) => { %>
                                <article class="saved-merchant-row">
                                    <div>
                                        <strong><%= booking.service_name %></strong>
                                        <span>
                                            <%= booking.merchant_name %>
                                            &middot;
                                            <%= new Date(booking.booking_date).toLocaleDateString('en-SG', { dateStyle: 'medium' }) %>
                                            <% if (booking.booking_time) { %>
                                                at <%= booking.booking_time %>
                                            <% } %>
                                        </span>
                                    </div>
                                    <a class="button secondary" href="/receipt/<%= booking.id %>">View QR</a>
                                </article>
                            <% }) %>
                        </div>
                    <% } %>
                </section>

                <section class="account-panel profile-tab-panel" data-profile-panel="bookings">
                    <div class="account-panel-header">
                        <div>
                            <p class="eyebrow">History</p>
                            <h2>Past Bookings</h2>
                        </div>
                    </div>

                    <% if (!profilePastBookings.length) { %>
                        <p class="muted">No completed bookings yet.</p>
                    <% } else { %>
                        <div class="saved-merchant-list">
                            <% profilePastBookings.forEach((booking) => { %>
                                <article class="saved-merchant-row">
                                    <div>
                                        <strong><%= booking.service_name %></strong>
                                        <span>
                                            <%= booking.merchant_name %>
                                            &middot;
                                            <%= new Date(booking.booking_date).toLocaleDateString('en-SG', { dateStyle: 'medium' }) %>
                                            <% if (booking.booking_time) { %>
                                                at <%= booking.booking_time %>
                                            <% } %>
                                        </span>
                                    </div>
                                    <a class="button secondary" href="/receipt/<%= booking.id %>">View</a>
                                </article>
                            <% }) %>
                        </div>
                    <% } %>
                </section>

                <section id="membership" class="account-panel account-membership-panel profile-tab-panel" data-profile-panel="membership">
                    <div class="account-panel-header">
                        <div>
                            <p class="eyebrow">Membership</p>
                            <h2>Rewards summary</h2>
                        </div>
                        <span class="membership-tier-badge <%= member.tier.toLowerCase() %>">
                            <span><%= member.tier %></span>
                            <small>Tier</small>
                        </span>
                    </div>

                    <div class="account-membership-strip">
                        <div>
                            <strong><%= member.points %></strong>
                            <span>Points</span>
                        </div>
                        <div>
                            <strong><%= Number.isFinite(profile.glintsBalance) ? profile.glintsBalance : 0 %></strong>
                            <span>VaniGlints</span>
                        </div>
                        <div>
                            <strong>$<%= cashbackBalance %></strong>
                            <span>Cashback</span>
                        </div>
                        <div>
                            <strong><%= favourites.length %></strong>
                            <span>Saved merchants</span>
                        </div>
                        <div>
                            <strong><%= cartCount %></strong>
                            <span>Cart items</span>
                        </div>
                    </div>

                    <div class="account-progress">
                        <div>
                            <span>Bronze</span>
                            <span>Platinum</span>
                        </div>
                        <div class="membership-progress" aria-label="Membership progress">
                            <span style="width:<%= member.progress %>%"></span>
                        </div>
                        <p class="muted">
                            <%= member.next > 0
                                ? member.next + " points to Platinum"
                                : "Maximum tier reached" %>
                        </p>
                    </div>
                </section>

                <section id="wallet" class="account-panel loyalty-profile-panel profile-tab-panel" data-profile-panel="wallet">
                    <div class="account-panel-header">
                        <div>
                            <p class="eyebrow">Wallet</p>
                            <h2>Loyalty & rewards</h2>
                        </div>
                        <a class="button secondary" href="/profile/history">Purchase history</a>
                    </div>

                    <div class="loyalty-balance">
                        <div>
                            <span>Points</span>
                            <strong><%= loyalty ? loyalty.wallet.pointsBalance : 0 %></strong>
                        </div>
                        <div>
                            <span>Cashback</span>
                            <strong>$<%= loyalty ? Number(loyalty.wallet.cashbackBalance || 0).toFixed(2) : '0.00' %></strong>
                        </div>
                        <div>
                            <span>Lifetime points</span>
                            <strong><%= loyalty ? loyalty.wallet.lifetimePoints : 0 %></strong>
                        </div>
                    </div>

                    <% if (loyalty) { %>
                        <div class="loyalty-rule-strip">
                            <p><span>Earn</span><strong><%= loyalty.rules.pointsPerDollar %> pts / $1</strong></p>
                            <p><span>Cashback</span><strong><%= loyalty.rules.cashbackPercent %>%</strong></p>
                            <p><span>Redeem</span><strong><%= loyalty.rules.minPointsToRedeem %> pts min</strong></p>
                        </div>

                        <form class="loyalty-inline-redeem" action="/wallet/redeem" method="POST">
                            <label>
                                Convert points into cashback
                                <input type="number" name="points" min="<%= loyalty.rules.minPointsToRedeem %>" step="1" max="<%= loyalty.wallet.pointsBalance %>" value="<%= loyalty.wallet.pointsBalance >= loyalty.rules.minPointsToRedeem ? loyalty.rules.minPointsToRedeem : 0 %>" <%= loyalty.wallet.pointsBalance < loyalty.rules.minPointsToRedeem ? 'disabled' : '' %>>
                            </label>
                            <button class="button primary" type="submit" <%= loyalty.wallet.pointsBalance < loyalty.rules.minPointsToRedeem ? 'disabled' : '' %>>Redeem</button>
                        </form>

                        <% if (!loyalty.transactions.length) { %>
                            <p class="muted">No wallet transactions yet. Complete a paid booking or checkout to earn rewards.</p>
                        <% } else { %>
                            <div class="wallet-mini-history">
                                <% loyalty.transactions.slice(0, 5).forEach((entry) => { %>
                                    <p>
                                        <span><%= new Date(entry.createdAt).toLocaleDateString('en-SG', { dateStyle: 'medium' }) %></span>
                                        <strong><%= entry.description %></strong>
                                        <em>
                                            <%= entry.pointsDelta > 0 ? '+' : '' %><%= entry.pointsDelta %> pts
                                            &middot;
                                            <%= entry.cashbackDelta >= 0 ? '+' : '-' %>$<%= Math.abs(Number(entry.cashbackDelta || 0)).toFixed(2) %>
                                        </em>
                                    </p>
                                <% }) %>
                            </div>
                        <% } %>
                    <% } else { %>
                        <p class="muted">Wallet details could not be loaded right now.</p>
                    <% } %>
                </section>

                <% if (referral) { %>
                    <section id="referral" class="account-panel account-referral-panel profile-tab-panel" data-profile-panel="membership">
                        <div class="account-panel-header">
                            <div>
                                <p class="eyebrow">Referral</p>
                                <h2>Your referral code</h2>
                            </div>
                            <a class="button secondary" href="<%= referral.mailto %>">Invite by email</a>
                        </div>

                        <div class="referral-code-card">
                            <span>Share this code with friends</span>
                            <strong><%= referral.code %></strong>
                            <input type="text" value="<%= referral.link %>" readonly aria-label="Referral link">
                        </div>

                        <div class="referral-metrics">
                            <div>
                                <strong>$<%= referral.discount %></strong>
                                <span>Friend discount</span>
                            </div>
                            <div>
                                <strong><%= referral.reward %></strong>
                                <span>Glints per successful referral</span>
                            </div>
                        </div>

                        <div class="referral-mini-tracker">
                            <div>
                                <span>Successful referrals</span>
                                <strong><%= referral.successfulReferrals || 0 %></strong>
                            </div>
                            <div>
                                <span>VaniGlints earned</span>
                                <strong><%= referral.earnedGlints || 0 %></strong>
                            </div>
                            <div>
                                <span>Next referral reward</span>
                                <strong>+<%= referral.nextReward || referral.reward %></strong>
                            </div>
                        </div>
                    </section>
                <% } %>

                <% if (favourites.length > 0) { %>
                    <section class="account-panel saved-merchants-panel profile-tab-panel" data-profile-panel="profile-details">
                        <div class="account-panel-header">
                            <div>
                                <p class="eyebrow">Saved</p>
                                <h2>Saved merchants</h2>
                            </div>
                            <a class="text-button" href="/services">Find more</a>
                        </div>

                        <div class="saved-merchant-list">
                            <% favourites.slice(0, 3).forEach((merchant) => { %>
                                <article class="saved-merchant-row">
                                    <div>
                                        <strong><%= merchant.name %></strong>
                                        <span><%= merchant.location %> &middot; Rating <%= merchant.rating %></span>
                                    </div>
                                    <a class="button secondary" href="/merchants/<%= merchant.id %>">View</a>
                                </article>
                            <% }) %>
                        </div>
                    </section>
                <% } %>
            <% } %>
        </div>
    </div>
</section>

<script>
    (() => {
        const tabs = Array.from(document.querySelectorAll('[data-profile-tab]'));
        const panels = Array.from(document.querySelectorAll('[data-profile-panel]'));

        if (!tabs.length || !panels.length) {
            return;
        }

        const defaultPanel = tabs[0].dataset.profileTab;
        const showPanel = (panelName) => {
            const targetPanel = panels.some((panel) => panel.dataset.profilePanel === panelName)
                ? panelName
                : defaultPanel;

            panels.forEach((panel) => {
                panel.hidden = panel.dataset.profilePanel !== targetPanel;
            });

            tabs.forEach((tab) => {
                const isActive = tab.dataset.profileTab === targetPanel;
                tab.classList.toggle('is-active', isActive);
                tab.setAttribute('aria-current', isActive ? 'page' : 'false');
            });
        };

        tabs.forEach((tab) => {
            tab.addEventListener('click', (event) => {
                event.preventDefault();
                const panelName = tab.dataset.profileTab;
                history.replaceState(null, '', `#${panelName}`);
                showPanel(panelName);
            });
        });

        showPanel(window.location.hash.replace('#', '') || defaultPanel);
    })();
</script>

<%- include('partials/footer') %>
