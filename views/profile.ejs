<%- include('partials/header', { title }) %>

<%
    const progress = Math.min((member.points / 10000) * 100, 100);
    const next = Math.max(10000 - member.points, 0);
    const tiers = [
        { name: 'Bronze', points: '0+', detail: 'Entry level', className: 'bronze' },
        { name: 'Silver', points: '2,000+', detail: 'Bonus rewards', className: 'silver' },
        { name: 'Gold', points: '5,000+', detail: 'Priority perks', className: 'gold' },
        { name: 'Platinum', points: '10,000+', detail: 'VIP benefits', className: 'platinum' }
    ];
%>

<section class="page-title">
    <p class="eyebrow">Profile</p>
    <h1>Manage your Vaniday profile and membership.</h1>
    <p>Edit your personal details, view saved merchants, track cashback, and follow your membership rewards.</p>
</section>

<section class="section compact">
    <% if (success) { %>
        <div class="notice success"><%= success %></div>
    <% } %>
    <% if (error) { %>
        <div class="notice error"><%= error %></div>
    <% } %>

    <div class="profile-dashboard">
        <form class="profile-form" action="/profile" method="POST">
            <div>
                <p class="eyebrow">Personal Details</p>
                <h2>Edit profile</h2>
            </div>

            <label>
                Full name
                <input type="text" name="name" value="<%= profile.name %>" placeholder="Enter your name">
            </label>

            <label>
                Email
                <input type="email" name="email" value="<%= profile.email %>" placeholder="name@example.com">
            </label>

            <label>
                Handphone number
                <input type="tel" name="phone" value="<%= profile.phone %>" placeholder="81234567" maxlength="8">
            </label>

            <button class="button primary full" type="submit">Save profile</button>
        </form>

        <aside class="reward-panel">
            <p class="eyebrow">Cashback & Rewards</p>
            <h2>$<%= cashbackBalance %></h2>
            <p class="muted">Available cashback balance</p>

            <div class="reward-stats">
                <div>
                    <strong><%= rewardPoints %></strong>
                    <span>Reward points</span>
                </div>
                <div>
                    <strong><%= member.tier %></strong>
                    <span>Membership tier</span>
                </div>
                <div>
                    <strong><%= favourites.length %></strong>
                    <span>Saved merchants</span>
                </div>
                <div>
                    <strong><%= cartCount %></strong>
                    <span>Cart items</span>
                </div>
            </div>

            <a class="button secondary full" href="/cashback">View cashback details</a>
            <a class="button secondary full" href="#membership">View membership perks</a>
            <form action="/logout" method="POST">
                <button class="text-button full" type="submit">Log out</button>
            </form>
        </aside>
    </div>

    <div id="membership" class="section-heading profile-heading">
        <p class="eyebrow">Membership</p>
        <h2>Your rewards, points, and perks</h2>
    </div>

    <div class="membership-overview">
        <article class="membership-points-card">
            <p class="eyebrow">Current Tier</p>
            <div class="membership-tier-badge <%= member.tier.toLowerCase() %>">
                <span><%= member.tier %></span>
                <small>Tier</small>
            </div>
            <h2><%= member.points %> Points</h2>
            <p class="muted">
                <%= next > 0
                    ? next + " points to reach Platinum"
                    : "Maximum tier reached" %>
            </p>
            <div class="membership-progress" aria-label="Membership progress">
                <span style="width:<%= progress %>%"></span>
            </div>
            <div class="membership-progress-labels">
                <span>Bronze</span>
                <span>Platinum</span>
            </div>
        </article>

        <article class="membership-feature-card">
            <div>
                <p class="tag">Rewards wallet</p>
                <h2>Earn while you book.</h2>
                <p class="muted">Every saved merchant and selected item contributes to your rewards balance.</p>
                <div class="membership-actions">
                    <a class="button primary" href="/services">Book services</a>
                    <a class="button secondary" href="/products">Shop products</a>
                </div>
            </div>
            <div class="membership-feature-image" aria-label="Spa products and leaves"></div>
        </article>
    </div>

    <div class="section-heading profile-heading">
        <p class="eyebrow">Tiers</p>
        <h2>Membership levels</h2>
    </div>

    <div class="membership-tier-grid">
        <% tiers.forEach((tier) => { %>
            <article class="membership-tier-card <%= tier.className %> <%= member.tier === tier.name ? 'active' : '' %>">
                <div class="tier-medallion">
                    <span><%= tier.name.charAt(0) %></span>
                </div>
                <div>
                    <h3><%= tier.name %></h3>
                    <p><%= tier.points %> points</p>
                    <span><%= tier.detail %></span>
                </div>
            </article>
        <% }) %>
    </div>

    <div class="section-heading profile-heading">
        <p class="eyebrow">Unlockable Rewards</p>
        <h2>Vouchers and gift cards</h2>
    </div>

    <div class="membership-reward-grid">
        <% if (member.tier === 'Bronze' || member.tier === 'Silver' || member.tier === 'Gold' || member.tier === 'Platinum') { %>
            <article class="membership-reward-card reward-discount">
                <div class="reward-image" aria-label="Green beauty product voucher"></div>
                <div>
                    <p class="tag">Available</p>
                    <h3>5% Discount Voucher</h3>
                    <p class="muted">Available at all tiers</p>
                </div>
            </article>
        <% } %>

        <% if (member.tier === 'Silver' || member.tier === 'Gold' || member.tier === 'Platinum') { %>
            <article class="membership-reward-card reward-gift">
                <div class="reward-image" aria-label="Gift card reward"></div>
                <div>
                    <p class="tag">Silver</p>
                    <h3>$10 Gift Card</h3>
                    <p class="muted">Unlock at Silver tier</p>
                </div>
            </article>
        <% } %>

        <% if (member.tier === 'Gold' || member.tier === 'Platinum') { %>
            <article class="membership-reward-card reward-upgrade">
                <div class="reward-image" aria-label="Service upgrade reward"></div>
                <div>
                    <p class="tag">Gold</p>
                    <h3>Free Service Upgrade</h3>
                    <p class="muted">Unlock at Gold tier</p>
                </div>
            </article>
        <% } %>

        <% if (member.tier === 'Platinum') { %>
            <article class="membership-reward-card reward-premium">
                <div class="reward-image" aria-label="Exclusive gift card reward"></div>
                <div>
                    <p class="tag">Platinum</p>
                    <h3>$50 Exclusive Gift Card</h3>
                    <p class="muted">Unlock at Platinum tier</p>
                </div>
            </article>
        <% } %>
    </div>

    <div class="section-heading profile-heading">
        <p class="eyebrow">Saved Merchants</p>
        <h2>Your favourites</h2>
    </div>

    <% if (favourites.length === 0) { %>
        <div class="empty-state">
            <h2>No saved merchants yet.</h2>
            <p class="muted">Tap the heart on any merchant to save it here.</p>
            <a class="button primary" href="/services">Find services</a>
        </div>
    <% } else { %>
        <div class="merchant-grid">
            <% favourites.forEach((merchant) => { %>
                <article class="merchant-card">
                    <div>
                        <p class="tag"><%= merchant.category %></p>
                        <h3><%= merchant.name %></h3>
                        <p class="muted"><%= merchant.location %> &middot; Rating <%= merchant.rating %></p>
                        <p><%= merchant.description %></p>
                    </div>
                    <div class="card-footer">
                        <a class="button secondary" href="/merchants/<%= merchant.id %>">View merchant</a>
                        <form action="/merchants/<%= merchant.id %>/favourite" method="POST">
                            <button class="heart-button active" type="submit">&hearts;</button>
                        </form>
                    </div>
                </article>
            <% }) %>
        </div>
    <% } %>
</section>

<%- include('partials/footer') %>
