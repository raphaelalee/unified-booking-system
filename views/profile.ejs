<%- include('partials/header', { title }) %>

<section class="page-title">
    <p class="eyebrow"><%= roleLabel %> Profile</p>
    <h1>Account settings.</h1>
    <p>Keep your contact details and password up to date.</p>
</section>

<section class="section compact account-settings-page">
    <% if (success) { %>
        <div class="notice success"><%= success %></div>
    <% } %>
    <% if (error) { %>
        <div class="notice error"><%= error %></div>
    <% } %>

    <div class="account-layout">
        <aside class="account-summary-panel">
            <div class="account-avatar" aria-hidden="true">
                <%= (profile.name || roleLabel || 'V').charAt(0).toUpperCase() %>
            </div>

            <div class="account-name-block">
                <span class="account-role-chip"><%= roleLabel %></span>
                <h2><%= profile.name %></h2>
                <p><%= profile.email %></p>
            </div>

            <dl class="account-summary-list">
                <div>
                    <dt>Phone</dt>
                    <dd><%= profile.phone || 'Not set' %></dd>
                </div>
                <% if (isCustomer) { %>
                    <div>
                        <dt>Membership</dt>
                        <dd><%= member.tier %></dd>
                    </div>
                    <div>
                        <dt>VaniGlints</dt>
                        <dd><%= Number.isFinite(profile.glintsBalance) ? profile.glintsBalance : 0 %> pts</dd>
                    </div>
                    <div>
                        <dt>Cashback</dt>
                        <dd>$<%= cashbackBalance %></dd>
                    </div>
                    <% if (referral) { %>
                        <div>
                            <dt>Referral code</dt>
                            <dd><%= referral.code %></dd>
                        </div>
                    <% } %>
                <% } else { %>
                    <div>
                        <dt>Dashboard</dt>
                        <dd><a href="<%= dashboardPath %>">Open dashboard</a></dd>
                    </div>
                <% } %>
            </dl>

            <div class="account-actions">
                <% if (isCustomer) { %>
                    <a class="button primary full" href="/services">Book services</a>
                    <a class="button secondary full" href="/rewards-game">Rewards game</a>
                    <a class="button secondary full" href="/cashback">Cashback</a>
                <% } else { %>
                    <a class="button primary full" href="<%= dashboardPath %>">Back to dashboard</a>
                <% } %>
                <form action="/logout" method="POST">
                    <button class="text-button full" type="submit">Log out</button>
                </form>
            </div>
        </aside>

        <div class="account-main-stack">
            <form class="account-panel account-form" action="/profile" method="POST">
                <div class="account-panel-header">
                    <div>
                        <p class="eyebrow">Details</p>
                        <h2>Personal information</h2>
                    </div>
                </div>

                <div class="form-grid">
                    <label>
                        Full name
                        <input type="text" name="name" value="<%= profile.name %>" placeholder="Enter your name" autocomplete="name" required>
                    </label>

                    <label>
                        Email
                        <input type="email" name="email" value="<%= profile.email %>" placeholder="name@example.com" autocomplete="email" required>
                    </label>

                    <label>
                        Handphone number
                        <input type="tel" name="phone" value="<%= profile.phone %>" placeholder="81234567" maxlength="8" pattern="[689][0-9]{7}" autocomplete="tel">
                    </label>
                </div>

                <div class="account-form-actions">
                    <button class="button primary" type="submit">Save changes</button>
                </div>
            </form>

            <form class="account-panel account-form" action="/profile/password" method="POST">
                <div class="account-panel-header">
                    <div>
                        <p class="eyebrow">Security</p>
                        <h2>Change password</h2>
                    </div>
                </div>

                <div class="form-grid">
                    <label>
                        Current password
                        <input type="password" name="currentPassword" placeholder="Current password" autocomplete="current-password" required>
                    </label>

                    <label>
                        New password
                        <input type="password" name="newPassword" placeholder="New password" autocomplete="new-password" minlength="8" required>
                    </label>

                    <label>
                        Confirm new password
                        <input type="password" name="confirmPassword" placeholder="Confirm password" autocomplete="new-password" minlength="8" required>
                    </label>
                </div>

                <div class="password-requirements">
                    <span>Current password required</span>
                    <span>8+ characters</span>
                    <span>Letters and numbers</span>
                </div>

                <div class="account-form-actions">
                    <button class="button primary" type="submit">Update password</button>
                </div>
            </form>

            <% if (isCustomer) { %>
                <section id="membership" class="account-panel account-membership-panel">
                    <div class="account-panel-header">
                        <div>
                            <p class="eyebrow">Membership</p>
                            <h2>Rewards summary</h2>
                        </div>
                        <span class="membership-tier-badge <%= member.tier.toLowerCase() %>">
                            <span><%= member.tier %></span>
                            <small>Tier</small>
                        </span>
                    </div>

                    <div class="account-membership-strip">
                        <div>
                            <strong><%= member.points %></strong>
                            <span>Points</span>
                        </div>
                        <div>
                            <strong><%= Number.isFinite(profile.glintsBalance) ? profile.glintsBalance : 0 %></strong>
                            <span>VaniGlints</span>
                        </div>
                        <div>
                            <strong>$<%= cashbackBalance %></strong>
                            <span>Cashback</span>
                        </div>
                        <div>
                            <strong><%= favourites.length %></strong>
                            <span>Saved merchants</span>
                        </div>
                        <div>
                            <strong><%= cartCount %></strong>
                            <span>Cart items</span>
                        </div>
                    </div>

                    <div class="account-progress">
                        <div>
                            <span>Bronze</span>
                            <span>Platinum</span>
                        </div>
                        <div class="membership-progress" aria-label="Membership progress">
                            <span style="width:<%= member.progress %>%"></span>
                        </div>
                        <p class="muted">
                            <%= member.next > 0
                                ? member.next + " points to Platinum"
                                : "Maximum tier reached" %>
                        </p>
                    </div>
                </section>

                <% if (referral) { %>
                    <section id="referral" class="account-panel account-referral-panel">
                        <div class="account-panel-header">
                            <div>
                                <p class="eyebrow">Referral</p>
                                <h2>Your referral code</h2>
                            </div>
                            <a class="button secondary" href="<%= referral.mailto %>">Invite by email</a>
                        </div>

                        <div class="referral-code-card">
                            <span>Share this code with friends</span>
                            <strong><%= referral.code %></strong>
                            <input type="text" value="<%= referral.link %>" readonly aria-label="Referral link">
                        </div>

                        <div class="referral-metrics">
                            <div>
                                <strong>$<%= referral.discount %></strong>
                                <span>Friend discount</span>
                            </div>
                            <div>
                                <strong><%= referral.reward %></strong>
                                <span>Glints per successful referral</span>
                            </div>
                        </div>
                    </section>
                <% } %>

                <% if (favourites.length > 0) { %>
                    <section class="account-panel saved-merchants-panel">
                        <div class="account-panel-header">
                            <div>
                                <p class="eyebrow">Saved</p>
                                <h2>Saved merchants</h2>
                            </div>
                            <a class="text-button" href="/services">Find more</a>
                        </div>

                        <div class="saved-merchant-list">
                            <% favourites.slice(0, 3).forEach((merchant) => { %>
                                <article class="saved-merchant-row">
                                    <div>
                                        <strong><%= merchant.name %></strong>
                                        <span><%= merchant.location %> &middot; Rating <%= merchant.rating %></span>
                                    </div>
                                    <a class="button secondary" href="/merchants/<%= merchant.id %>">View</a>
                                </article>
                            <% }) %>
                        </div>
                    </section>
                <% } %>
            <% } %>
        </div>
    </div>
</section>

<%- include('partials/footer') %>
