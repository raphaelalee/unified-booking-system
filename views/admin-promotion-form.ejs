<%- include('partials/header', { title }) %>

<section class="page-title">
    <p class="eyebrow">Admin Portal</p>
    <h1><%= promotion ? 'Edit promotion' : 'Add promotion' %>.</h1>
    <p>Admins can update or correct promotions across any merchant salon.</p>
</section>

<section class="section compact">
    <form class="login-form service-admin-form" action="<%= promotion ? `/admin/promotions/${promotion.id}` : '/admin/promotions' %>" method="POST">
        <% if (errors.length > 0) { %>
            <div class="notice error">
                <% errors.forEach((error) => { %>
                    <p><%= error %></p>
                <% }) %>
            </div>
        <% } %>

        <label>
            Merchant salon
            <select name="salonId" required>
                <option value="">Select merchant salon</option>
                <% salons.forEach((salon) => { %>
                    <option value="<%= salon.salon_id %>" <%= String(form.salonId) === String(salon.salon_id) ? 'selected' : '' %>>
                        <%= salon.salon_name %> - <%= salon.owner_email %>
                    </option>
                <% }) %>
            </select>
        </label>

        <label>
            Linked service
            <select name="serviceId">
                <option value="">All merchant services</option>
                <% services.forEach((service) => { %>
                    <option value="<%= service.id %>" <%= String(form.serviceId) === String(service.id) ? 'selected' : '' %>>
                        <%= service.salonName %> - <%= service.name %>
                    </option>
                <% }) %>
            </select>
        </label>

        <label>
            Promotion title
            <input type="text" name="title" value="<%= form.title %>" placeholder="Weekday Happy Hour Facial" required>
        </label>

        <label>
            Promotion type
            <select name="type" required>
                <% promotionTypes.forEach((type) => { %>
                    <option value="<%= type %>" <%= form.type === type ? 'selected' : '' %>><%= type.replace(/_/g, ' ') %></option>
                <% }) %>
            </select>
        </label>

        <label>
            Discount type
            <select name="discountType" required>
                <% discountTypes.forEach((type) => { %>
                    <option value="<%= type %>" <%= form.discountType === type ? 'selected' : '' %>><%= type.replace(/_/g, ' ') %></option>
                <% }) %>
            </select>
        </label>

        <label>
            Discount value
            <input type="number" name="discountValue" value="<%= form.discountValue %>" min="0" step="0.01" placeholder="20">
        </label>

        <label>
            Start date
            <input type="datetime-local" name="startDate" value="<%= form.startDate %>" required>
        </label>

        <label>
            End date
            <input type="datetime-local" name="endDate" value="<%= form.endDate %>" required>
        </label>

        <label>
            Status
            <select name="status" required>
                <% statuses.forEach((status) => { %>
                    <option value="<%= status %>" <%= form.status === status ? 'selected' : '' %>><%= status %></option>
                <% }) %>
            </select>
        </label>

        <label>
            Description
            <textarea name="description" placeholder="Explain what the promotion covers"><%= form.description %></textarea>
        </label>

        <label>
            Terms
            <textarea name="terms" placeholder="Valid weekdays only, once per customer, etc."><%= form.terms %></textarea>
        </label>

        <div class="form-actions">
            <button class="button primary" type="submit"><%= promotion ? 'Update promotion' : 'Create promotion' %></button>
            <a class="button secondary" href="/admin/promotions">Cancel</a>
        </div>
    </form>
</section>

<%- include('partials/footer') %>
