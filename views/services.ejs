<%- include('partials/header', { title }) %>

<%
    const serviceSearch = typeof search !== 'undefined' ? search : '';
    const serviceMerchants = typeof merchants !== 'undefined' ? merchants : [];
    const serviceFavouriteIds = typeof favouriteIds !== 'undefined' ? favouriteIds : [];
    const stats = typeof portalStats !== 'undefined' ? portalStats : {
        merchantCount: serviceMerchants.length,
        serviceCount: 0,
        promotionCount: 0,
        slotCount: 0,
        startingPrice: 0
    };
    const allServices = typeof serviceCatalog !== 'undefined' ? serviceCatalog : [];
    const merchantTokenById = serviceMerchants.reduce((tokens, merchant) => {
        tokens[merchant.id] = merchant.qrToken;
        return tokens;
    }, {});
    const filteredServices = serviceSearch
        ? allServices.filter((service) => {
            const text = [
                service.name,
                service.duration,
                service.price,
                service.merchantName,
                service.merchantLocation,
                service.merchantCategory,
                service.merchantPromotion,
                service.merchantIntegrationStatus
            ].join(' ').toLowerCase();

            return text.includes(serviceSearch.toLowerCase());
        })
        : allServices;
%>

<section class="page-title services-unified-hero">
    <div>
        <p class="eyebrow">Services</p>
        <h1>Browse available beauty and wellness services.</h1>
        <p>
            Compare treatments, prices, time slots and promotions from Vaniday merchants before booking.
        </p>
        <form class="portal-search services-search" action="/services" method="GET">
            <input
                type="search"
                name="search"
                value="<%= serviceSearch %>"
                placeholder="Search services, merchants, locations, or promotions"
            >
            <button class="button primary" type="submit">Search</button>
        </form>
    </div>

    <aside class="portal-summary-panel services-summary-panel" aria-label="Services and merchant summary">
        <div class="portal-stat">
            <span>Merchants</span>
            <strong><%= stats.merchantCount %></strong>
        </div>
        <div class="portal-stat">
            <span>Services</span>
            <strong><%= filteredServices.length %></strong>
        </div>
        <div class="portal-stat">
            <span>Open slots</span>
            <strong><%= stats.slotCount %></strong>
        </div>
        <div class="portal-stat">
            <span>From</span>
            <strong>$<%= stats.startingPrice %></strong>
        </div>
    </aside>
</section>

<section class="section compact">
    <div class="section-heading services-list-heading">
        <p class="eyebrow">Service Catalog</p>
        <h2>Available services</h2>
    </div>

    <% if (filteredServices.length === 0) { %>
        <div class="notice">
            No services matched your search. Try hair, facial, spa, nails, massage, barber, or a location.
        </div>
    <% } else { %>
        <div class="service-catalog-grid unified-service-grid">
            <% filteredServices.forEach((service) => { %>
                <%
                    const merchantQrToken = service.merchantQrToken || merchantTokenById[service.merchantId];
                    const serviceBookingPath = merchantQrToken
                        ? service.serviceBookingPath || `/booking/${service.merchantId}/${merchantQrToken}?serviceId=${service.id}`
                        : `/merchants/${service.merchantId}`;
                %>
                <article class="service-catalog-card unified-service-card">
                    <div class="portal-card-header">
                        <span class="tag"><%= service.merchantCategory %></span>
                        <span class="service-price slim">$<%= service.price %></span>
                    </div>
                    <div>
                        <h3><%= service.name %></h3>
                        <p class="muted"><%= service.merchantName %> &middot; <%= service.merchantLocation %></p>
                        <p class="service-duration-line"><%= service.duration %></p>
                        <% if (Array.isArray(service.options) && service.options.length > 0) { %>
                            <div class="service-option-list">
                                <% service.options.slice(0, 4).forEach((option) => { %>
                                    <span><%= option.name %></span>
                                <% }) %>
                            </div>
                        <% } %>
                    </div>
                    <div class="service-card-footer">
                        <div>
                            <span class="service-card-label">Available slots</span>
                            <div class="availability-strip compact-slots">
                                <% (service.slots || []).slice(0, 3).forEach((slot) => { %>
                                    <span><%= slot %></span>
                                <% }) %>
                            </div>
                        </div>
                        <% if (service.merchantPromotion) { %>
                            <p class="promotion"><%= service.merchantPromotion %></p>
                        <% } %>
                    </div>
                    <div class="service-card-actions">
                        <a class="button primary full" href="<%= serviceBookingPath %>">Book this service</a>
                    </div>
                </article>
            <% }) %>
        </div>
    <% } %>

    <div class="section-cta services-directory-cta">
        <div>
            <h2>Prefer browsing by merchant?</h2>
            <p class="muted">Open the merchant directory to compare salons, ratings and full service menus.</p>
        </div>
        <a class="button secondary" href="/merchants">View merchant directory</a>
    </div>
</section>

<%- include('partials/footer') %>
