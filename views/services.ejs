<%- include('partials/header', { title }) %>

<%
    const serviceSearch = typeof search !== 'undefined' ? search : '';
    const serviceMerchants = typeof merchants !== 'undefined' ? merchants : [];
    const serviceFavouriteIds = typeof favouriteIds !== 'undefined' ? favouriteIds : [];
    const merchantTokenById = serviceMerchants.reduce((tokens, merchant) => {
        tokens[merchant.id] = merchant.qrToken;
        return tokens;
    }, {});
    const fallbackCatalog = [
        {
            id: 101,
            name: 'Hair Cut & Styling',
            duration: '60 mins',
            price: 45,
            slots: ['10:00 AM', '2:00 PM', '5:00 PM'],
            merchantId: 1,
            merchantName: 'Vaniday Beauty Studio',
            merchantQrToken: 'vaniday-beauty-studio-orchard',
            serviceBookingPath: '/booking/1/vaniday-beauty-studio-orchard?serviceId=101',
            serviceBookingUrl: '/booking/1/vaniday-beauty-studio-orchard?serviceId=101',
            merchantLocation: 'Orchard',
            merchantCategory: 'Beauty & Wellness'
        },
        {
            id: 102,
            name: 'Express Facial',
            duration: '45 mins',
            price: 55,
            slots: ['11:00 AM', '3:30 PM'],
            merchantId: 1,
            merchantName: 'Vaniday Beauty Studio',
            merchantQrToken: 'vaniday-beauty-studio-orchard',
            serviceBookingPath: '/booking/1/vaniday-beauty-studio-orchard?serviceId=102',
            serviceBookingUrl: '/booking/1/vaniday-beauty-studio-orchard?serviceId=102',
            merchantLocation: 'Orchard',
            merchantCategory: 'Beauty & Wellness'
        },
        {
            id: 201,
            name: 'Aromatherapy Massage',
            duration: '90 mins',
            price: 98,
            slots: ['9:30 AM', '1:00 PM', '6:00 PM'],
            merchantId: 2,
            merchantName: 'FreshGlow Spa',
            merchantQrToken: 'freshglow-spa-tampines',
            serviceBookingPath: '/booking/2/freshglow-spa-tampines?serviceId=201',
            serviceBookingUrl: '/booking/2/freshglow-spa-tampines?serviceId=201',
            merchantLocation: 'Tampines',
            merchantCategory: 'Spa'
        },
        {
            id: 301,
            name: 'Classic Haircut',
            duration: '30 mins',
            price: 28,
            slots: ['10:00 AM', '1:30 PM', '7:00 PM'],
            merchantId: 3,
            merchantName: 'Urban Groom Barbers',
            merchantQrToken: 'urban-groom-barbers-woodlands',
            serviceBookingPath: '/booking/3/urban-groom-barbers-woodlands?serviceId=301',
            serviceBookingUrl: '/booking/3/urban-groom-barbers-woodlands?serviceId=301',
            merchantLocation: 'Woodlands',
            merchantCategory: 'Barber'
        }
    ];
    const allServices = typeof serviceCatalog !== 'undefined' && serviceCatalog.length > 0 ? serviceCatalog : fallbackCatalog;
    const filteredServices = serviceSearch
        ? allServices.filter((service) => {
            const text = [
                service.name,
                service.duration,
                service.price,
                service.merchantName,
                service.merchantLocation,
                service.merchantCategory
            ].join(' ').toLowerCase();

            return text.includes(serviceSearch.toLowerCase());
        })
        : allServices;
%>

<section class="page-title">
    <p class="eyebrow">Services</p>
    <h1>Beauty and wellness services for every routine.</h1>
    <p>Explore salon, spa, nail, facial, and grooming services from Vaniday merchants.</p>
</section>

<section class="section compact">
    <div class="content-grid">
        <article class="content-card image-card service-hair">
            <span>Hair</span>
            <h2>Cut, colour and styling</h2>
            <p>Book haircuts, blowouts, styling, colour refreshes, and treatment sessions.</p>
        </article>
        <article class="content-card image-card service-spa">
            <span>Spa</span>
            <h2>Massage and body care</h2>
            <p>Relax with aromatherapy massage, body scrubs, and wellness treatments.</p>
        </article>
        <article class="content-card image-card service-nails">
            <span>Nails</span>
            <h2>Manicure and pedicure</h2>
            <p>Choose express manicures, classic polish, nail care, and hand treatments.</p>
        </article>
        <article class="content-card image-card service-facial">
            <span>Facial</span>
            <h2>Skin and glow treatments</h2>
            <p>Find facials designed for hydration, cleansing, brightening, and recovery.</p>
        </article>
    </div>

    <div class="section-cta">
        <h2>Ready to book?</h2>
        <p class="muted">Pick a merchant below, choose a service, or use the QR booking link at the shop.</p>
    </div>

    <div class="section-heading profile-heading">
        <p class="eyebrow">All Services</p>
        <h2>Choose a service first</h2>
    </div>

    <% if (filteredServices.length === 0) { %>
        <div class="notice">
            No individual services matched your search. Try hair, facial, spa, nails, massage, or barber.
        </div>
    <% } else { %>
        <div class="service-catalog-grid">
            <% filteredServices.forEach((service) => { %>
                <%
                    const merchantQrToken = service.merchantQrToken || merchantTokenById[service.merchantId];
                    const serviceBookingPath = merchantQrToken
                        ? service.serviceBookingPath || `/booking/${service.merchantId}/${merchantQrToken}?serviceId=${service.id}`
                        : `/merchants/${service.merchantId}/qr`;
                    const serviceBookingUrl = service.serviceBookingUrl || serviceBookingPath;
                %>
                <article class="service-catalog-card">
                    <div>
                        <p class="tag"><%= service.merchantCategory %></p>
                        <h3><%= service.name %></h3>
                        <p class="muted"><%= service.merchantName %> &middot; <%= service.merchantLocation %></p>
                        <p><%= service.duration %> &middot; $<%= service.price %></p>
                        <p class="muted">Available: <%= service.slots.join(', ') %></p>
                    </div>
                    <div class="service-card-actions">
                        <a class="service-qr-link" href="<%= serviceBookingPath %>" aria-label="Open QR booking page for <%= service.name %>">
                            <img
                                class="service-qr-code"
                                src="https://api.qrserver.com/v1/create-qr-code/?size=120x120&data=<%= encodeURIComponent(serviceBookingUrl) %>"
                                alt="QR code for <%= service.name %> booking page"
                            >
                        </a>
                        <a class="button secondary" href="<%= serviceBookingPath %>">Book this</a>
                    </div>
                </article>
            <% }) %>
        </div>
    <% } %>

    <div class="section-heading profile-heading">
        <p class="eyebrow">Merchants</p>
        <h2>Book from Vaniday partners</h2>
    </div>

    <form class="search-bar" action="/services" method="GET">
        <input type="search" name="search" value="<%= serviceSearch %>" placeholder="Search services, merchants, category, or location">
        <button class="button primary" type="submit">Search</button>
    </form>

    <% if (serviceMerchants.length === 0) { %>
        <div class="notice">
            No services found. Try searching for hair, facial, spa, barber, or a location.
        </div>
    <% } %>

    <div class="merchant-list">
        <% serviceMerchants.forEach((merchant) => { %>
            <article class="merchant-row">
                <div class="merchant-thumb merchant-thumb-<%= merchant.id %>">
                    <span><%= merchant.category %></span>
                </div>
                <div>
                    <div class="merchant-title-row">
                        <p class="tag"><%= merchant.category %></p>
                        <form action="/merchants/<%= merchant.id %>/favourite" method="POST">
                            <button class="heart-button <%= serviceFavouriteIds.includes(merchant.id) ? 'active' : '' %>" type="submit" aria-label="Favourite <%= merchant.name %>">
                                <%- serviceFavouriteIds.includes(merchant.id) ? '&hearts;' : '&#9825;' %>
                            </button>
                        </form>
                    </div>
                    <h2><%= merchant.name %></h2>
                    <p class="muted"><%= merchant.location %> &middot; Rating <%= merchant.rating %></p>
                    <p><%= merchant.description %></p>
                    <p class="promotion"><%= merchant.promotion %></p>
                </div>
                <div class="merchant-actions">
                    <a class="button primary" href="/merchants/<%= merchant.id %>">View services</a>
                    <a class="text-link" href="/merchants/<%= merchant.id %>/qr">QR booking</a>
                </div>
            </article>
        <% }) %>
    </div>
</section>

<%- include('partials/footer') %>
