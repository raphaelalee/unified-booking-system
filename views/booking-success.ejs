<%- include('partials/header', { title }) %>

<section class="page-title">
    <p class="eyebrow">Booking confirmed</p>
    <h1>Your booking has been confirmed.</h1>
    <p>
        <strong><%= service.name %></strong> at <strong><%= merchant.name %></strong>
        on <strong><%= bookingDate %></strong> at <strong><%= bookingTime %></strong>.
        Please refer to your email for the confirmation details and check-in QR code.
    </p>
    <div class="hero-actions">
        <a class="button primary" href="/profile#bookings">View my bookings</a>
        <a class="button secondary" href="<%= typeof anotherBookingPath !== 'undefined' ? anotherBookingPath : '/merchant/' + merchant.id %>">Create another booking</a>
    </div>
</section>

<%- include('partials/footer') %>
