<%- include('partials/header', { title }) %>

<section class="page-title">
    <p class="eyebrow">Cart</p>
    <h1>Your selected items.</h1>
    <p>Review services and products before booking or checkout.</p>
</section>

<section class="section compact">
    <% if (cart.length === 0) { %>
        <div class="empty-state" id="empty-cart-state">
            <h2>Your cart is empty.</h2>
            <p class="muted">Add salon, spa, grooming services, or beauty products.</p>
            <div class="hero-actions">
                <a class="button primary" href="/services">Browse services</a>
                <a class="button secondary" href="/products">Shop products</a>
            </div>
        </div>
    <% } else { %>
        <div class="cart-layout">
            <div class="cart-list">
                <% cart.forEach((item) => { %>
                    <%
                        const bookingPath = `/booking/${item.merchantId}/${item.merchantQrToken}?serviceId=${item.serviceId}`;
                    %>
                    <article class="cart-item">
                        <div>
                            <p class="eyebrow"><%= item.type || 'Service' %> &middot; <%= item.merchantName %></p>
                            <h2><%= item.serviceName %></h2>
                            <p class="muted"><%= item.duration %> &middot; $<%= item.price %></p>
                            <p class="muted">Quantity: 1</p>
                        </div>
                        <div class="cart-item-actions">
                            <% if (item.merchantId) { %>
                                <a class="button secondary" href="<%= bookingPath %>">Book now</a>
                            <% } else { %>
                                <a class="button secondary" href="/payment?amount=<%= item.price %>&service=<%= encodeURIComponent(item.serviceName) %>&merchant=<%= encodeURIComponent(item.merchantName) %>">Pay now</a>
                            <% } %>
                            <form action="/cart/remove/<%= item.id %>" method="POST">
                                <button class="text-button" type="submit">Remove</button>
                            </form>
                        </div>
                    </article>
                <% }) %>
            </div>

            <aside class="booking-panel">
                <p class="eyebrow">Summary</p>
                <h2>$<%= total %></h2>
                <p class="muted"><%= cart.length %> item<%= cart.length === 1 ? '' : 's' %> selected</p>
                <a class="button secondary full" href="/payment?amount=<%= total %>&service=Cart checkout&merchant=Vaniday">Checkout and pay</a>
                <a class="button primary full" href="/services">Add more services</a>
                <a class="text-link" href="/products">Shop products</a>
            </aside>
        </div>
    <% } %>

    <div id="browser-product-cart"></div>
</section>

<script src="/js/cart-products.js"></script>

<%- include('partials/footer') %>
