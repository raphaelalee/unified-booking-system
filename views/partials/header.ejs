<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> | Vaniday</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <header class="site-header">
        <nav class="nav">
            <a class="brand" href="/">
                <span class="brand-mark">V</span>
                <span>Vaniday</span>
            </a>
            <div class="nav-links">
                <a href="/">Home</a>
                <a href="/services">Services</a>
                <a href="/products">Products</a>
                <a href="/membership">Membership</a>
                <a href="/cashback">Cashback</a>
                <a href="/giftcards">Gift Cards</a>
            </div>
            <div class="nav-tools">
                <div class="nav-support-links">
                    <a href="/about">About</a>
                    <a href="/contact">Contact</a>
                </div>
                <div class="nav-account-links">
                    <a class="profile-icon-link" href="/profile" aria-label="Profile">
                        <span class="login-icon" aria-hidden="true"></span>
                    </a>
                    <% if (currentUser) { %>
                        <form action="/logout" method="POST">
                            <button class="text-button" type="submit">Log Out</button>
                        </form>
                    <% } else { %>
                        <a class="signup-text-link" href="/signup">Sign Up</a>
                    <% } %>
                </div>
                <div class="nav-commerce-links">
                    <a class="bag-link" href="/cart" aria-label="Cart">
                        <span class="bag-icon" aria-hidden="true">
                            <span class="bag-count"><%= typeof cartCount !== 'undefined' ? cartCount : 0 %></span>
                        </span>
                    </a>
                </div>
            </div>
        </nav>
    </header>
    <main>
