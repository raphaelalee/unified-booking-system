<%- include('partials/header', { title }) %>

<section class="page-title">
    <p class="eyebrow">Payment</p>
    <h1>Complete your payment.</h1>
    <p>Pay securely for your Vaniday booking or product order.</p>
</section>

<section class="section compact">
    <div class="login-layout">
        <form class="login-form" action="/payment" method="POST">
            <input type="hidden" name="amount" value="<%= amount %>">
            <input type="hidden" name="merchantName" value="<%= merchantName %>">
            <input type="hidden" name="serviceName" value="<%= serviceName %>">
            <input type="hidden" name="cartItemId" value="<%= cartItemId || '' %>">
            <input type="hidden" name="cartCheckout" value="<%= cartCheckout ? 'true' : 'false' %>">
            <input type="hidden" name="checkoutId" value="<%= typeof checkoutId !== 'undefined' ? checkoutId : '' %>">
            <input type="hidden" name="bookingId" value="<%= typeof bookingId !== 'undefined' ? bookingId : '' %>">
            <input type="hidden" name="selectedItemIds" value="<%= Array.isArray(selectedItemIds) ? selectedItemIds.join(',') : (selectedItemIds || '') %>">
            <input type="hidden" name="fulfilment" value="<%= fulfilment || '' %>">
            <input type="hidden" name="pickupMerchantId" value="<%= pickupMerchantId || '' %>">
            <input type="hidden" name="deliveryAddress" value="<%= deliveryAddress || '' %>">
            <input type="hidden" name="deliveryUnit" value="<%= deliveryUnit || '' %>">
            <input type="hidden" name="deliveryPostal" value="<%= deliveryPostal || '' %>">
            <input type="hidden" name="deliveryPhone" value="<%= deliveryPhone || '' %>">

            <% if (typeof error !== 'undefined' && error) { %>
                <div class="notice error"><p><%= error %></p></div>
            <% } %>

            <div>
                <p class="eyebrow">Payment method</p>
                <h2>$<%= Number(amount).toFixed(2) %></h2>
                <p class="muted"><%= serviceName %> &middot; <%= merchantName %></p>
            </div>

            <fieldset>
                <legend class="eyebrow">Choose payment</legend>
                <label>
                    <input type="radio" name="paymentMethod" value="card" checked>
                    Card payment
                </label>
                <label>
                    <input type="radio" name="paymentMethod" value="nets">
                    NETS QR
                </label>
            </fieldset>

            <div id="card-payment-fields">
                <label>
                    Cardholder name
                    <input type="text" name="cardholderName" placeholder="Mary Tan">
                </label>

                <label>
                    Card number
                    <input type="text" name="cardNumber" placeholder="4242 4242 4242 4242" maxlength="19">
                </label>

                <div class="form-row">
                    <label>
                        Expiry
                        <input type="text" name="expiry" placeholder="MM/YY" maxlength="5">
                    </label>
                    <label>
                        CVV
                        <input type="password" name="cvv" placeholder="123" maxlength="3">
                    </label>
                </div>
            </div>

            <p id="nets-payment-note" class="muted" style="display:none;">
                Continue to generate a NETS QR code for this payment.
            </p>

            <button class="button primary full" type="submit">Continue payment</button>
        </form>

        <aside class="login-benefits">
            <p class="eyebrow">Payment summary</p>
            <h2><%= merchantName %></h2>
            <p><%= serviceName %></p>
            <p class="promotion">$<%= Number(amount).toFixed(2) %> total</p>
            <p class="muted">Prototype payment only. No real card charge is made.</p>
        </aside>
    </div>
</section>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const methodInputs = Array.from(document.querySelectorAll('input[name="paymentMethod"]'));
    const cardFields = document.getElementById('card-payment-fields');
    const netsNote = document.getElementById('nets-payment-note');

    function syncPaymentMethod() {
        const selected = methodInputs.find((input) => input.checked)?.value || 'card';
        if (cardFields) cardFields.style.display = selected === 'card' ? '' : 'none';
        if (netsNote) netsNote.style.display = selected === 'nets' ? '' : 'none';
    }

    methodInputs.forEach((input) => input.addEventListener('change', syncPaymentMethod));
    syncPaymentMethod();
});
</script>

<%- include('partials/footer') %>
